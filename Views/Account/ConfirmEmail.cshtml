@{
    Layout = null;
    var success = (bool)(ViewBag.Success ?? false);
    ViewData["Title"] = success ? "Email Verified" : "Verification Failed";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PeakMetrics</title>
    <link rel="icon" type="image/png" href="~/images/peakmetrics-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; }
        body {
            font-family: "Manrope", "Segoe UI", Tahoma, sans-serif;
            background: #eef2f9;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            min-height: 100vh;
        }
        .pm-confirm-card {
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 20px 48px rgba(16, 24, 40, 0.12);
            padding: 56px 48px;
            max-width: 520px;
            width: 100%;
            text-align: center;
        }
        .pm-icon-wrap {
            width: 72px; height: 72px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 24px;
        }
        .pm-icon-wrap.success { background: #f0fdf4; }
        .pm-icon-wrap.failure { background: #fef2f2; }
        .pm-icon-wrap svg { width: 36px; height: 36px; }
        .pm-icon-wrap.success svg { color: #16a34a; }
        .pm-icon-wrap.failure svg { color: #dc2626; }
        h1 { font-size: 1.6rem; font-weight: 800; color: #0f172a; margin-bottom: 12px; }
        p { color: #475569; line-height: 1.65; margin-bottom: 0; }
        .pm-btn-back {
            display: inline-block;
            margin-top: 28px;
            padding: 12px 28px;
            background: linear-gradient(120deg, #2563eb 0%, #1d4ed8 100%);
            color: #fff;
            border-radius: 10px;
            font-weight: 700;
            text-decoration: none;
            font-size: 0.95rem;
            transition: all 0.2s;
        }
        .pm-btn-back:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,0.3); color: #fff; }
        .pm-btn-register {
            display: inline-block;
            margin-top: 28px;
            padding: 12px 28px;
            background: transparent;
            color: #2563eb;
            border: 2px solid #2563eb;
            border-radius: 10px;
            font-weight: 700;
            text-decoration: none;
            font-size: 0.95rem;
            transition: all 0.2s;
        }
        .pm-btn-register:hover { background: #eff6ff; color: #1d4ed8; }
    </style>
</head>
<body>
    <div class="pm-confirm-card">
        @if (success)
        {
            <div class="pm-icon-wrap success">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h1>Email verified successfully!</h1>
            <p>
                Your account is now pending administrator approval.
                You will be able to log in once an admin approves your account.
            </p>
            <a href="/Home/Login" class="pm-btn-back">Back to Login</a>
        }
        else
        {
            <div class="pm-icon-wrap failure">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h1>Verification failed</h1>
            <p>
                Verification link is invalid or has expired. Please register again.
            </p>
            <a href="/Account/Register" class="pm-btn-register">Register again</a>
        }
    </div>
</body>
</html>
