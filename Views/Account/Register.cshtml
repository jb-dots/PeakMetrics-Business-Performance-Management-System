@model PeakMetrics.Web.ViewModels.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Register";
    var departments = ViewBag.Departments as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - PeakMetrics</title>
    <link rel="icon" type="image/png" href="~/images/peakmetrics-logo.png" />
    <link rel="shortcut icon" href="~/images/peakmetrics-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; }

        body {
            font-family: "Manrope", "Segoe UI", Tahoma, sans-serif;
            background: #eef2f9;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            min-height: 100vh;
        }

        .pm-card {
            width: min(1080px, 100%);
            display: flex;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 20px 48px rgba(16, 24, 40, 0.16);
            background: #fff;
        }

        /* ── Left panel ── */
        .pm-left {
            width: 45%;
            position: relative;
            overflow: hidden;
            color: #fff;
            padding: 52px 56px;
            background: linear-gradient(145deg, #2563eb 0%, #1d4ed8 55%, #1e40af 100%);
            display: flex;
            flex-direction: column;
        }

        .pm-left::before {
            content: "";
            position: absolute;
            width: 700px; height: 700px;
            border-radius: 50%;
            left: -160px; bottom: -400px;
            background: rgba(147, 197, 253, 0.18);
            pointer-events: none;
        }

        .pm-left::after {
            content: "";
            position: absolute;
            width: 500px; height: 500px;
            border-radius: 50%;
            right: -200px; top: -200px;
            background: rgba(147, 197, 253, 0.12);
            pointer-events: none;
        }

        .pm-left-content, .pm-left-foot { position: relative; z-index: 1; }

        .pm-kicker {
            margin: 0 0 18px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(219, 234, 254, 0.9);
        }

        .pm-headline {
            margin: 0 0 18px;
            font-size: clamp(2.4rem, 4vw, 3.6rem);
            font-weight: 800;
            line-height: 1.0;
            letter-spacing: -0.02em;
        }

        .pm-copy {
            margin: 0;
            font-size: 1rem;
            line-height: 1.5;
            color: rgba(219, 234, 254, 0.88);
            max-width: 420px;
        }

        .pm-left-foot {
            margin-top: auto;
            font-size: 0.88rem;
            color: rgba(219, 234, 254, 0.7);
        }

        /* ── Right panel ── */
        .pm-right {
            width: 55%;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 56px;
        }

        .pm-right-inner { width: 100%; }

        .pm-logo-wrap {
            text-align: center;
            margin-bottom: 16px;
        }

        .pm-logo-img {
            height: 100px;
            width: auto;
            display: block;
            margin: 0 auto;
            object-fit: contain;
        }

        .pm-form-title {
            margin: 0 0 4px;
            font-size: 1.7rem;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.02em;
        }

        .pm-form-sub {
            margin: 0 0 16px;
            font-size: 0.9rem;
            color: #64748b;
        }

        .pm-field { margin-bottom: 14px; }

        .pm-field label {
            display: block;
            margin-bottom: 5px;
            font-size: 0.88rem;
            font-weight: 600;
            color: #1e293b;
        }

        .pm-field input,
        .pm-field select {
            width: 100%;
            border: none;
            border-bottom: 2px solid #cbd5e1;
            border-radius: 0;
            background: transparent;
            padding: 9px 2px;
            font-size: 0.95rem;
            color: #0f172a;
            outline: none;
            transition: border-color 0.2s;
            appearance: none;
            -webkit-appearance: none;
        }

        .pm-field input:focus,
        .pm-field select:focus { border-bottom-color: #2563eb; }

        .pm-field input::placeholder { color: #94a3b8; }
        .pm-field input.is-invalid,
        .pm-field select.is-invalid { border-bottom-color: #ef4444; }

        .pm-error {
            margin-top: 4px;
            font-size: 0.8rem;
            color: #ef4444;
        }

        .pm-alert {
            padding: 10px 14px;
            border-radius: 8px;
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #b91c1c;
            font-size: 0.88rem;
            margin-bottom: 14px;
        }

        .pm-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0 20px; }

        .pm-btn {
            width: 100%;
            padding: 13px;
            border-radius: 10px;
            font-size: 0.98rem;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
        }

        .pm-btn-primary {
            background: linear-gradient(120deg, #2563eb 0%, #1d4ed8 100%);
            color: #fff;
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
            margin-top: 6px;
        }

        .pm-btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 24px rgba(37, 99, 235, 0.38);
        }

        @@keyframes pm-shake {
            0%, 100% { transform: translateX(0); }
            20%       { transform: translateX(-6px); }
            40%       { transform: translateX(6px); }
            60%       { transform: translateX(-4px); }
            80%       { transform: translateX(4px); }
        }

        .pm-shake { animation: pm-shake 0.4s ease; }

        @@media (max-width: 900px) {
            body { padding: 0; }
            .pm-card { flex-direction: column; height: auto; min-height: 100vh; border-radius: 0; box-shadow: none; }
            .pm-left, .pm-right { width: 100%; }
            .pm-left { padding: 36px 28px; min-height: 220px; }
            .pm-right { padding: 28px 24px 36px; align-items: flex-start; }
            .pm-row { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="pm-card">
        <section class="pm-left">
            <div class="pm-left-content">
                <p class="pm-kicker">Analytics &amp; Insights Platform</p>
                <h1 class="pm-headline">Join<br>PeakMetrics</h1>
                <p class="pm-copy">Submit your request to join your organization's performance management system.</p>
            </div>
            <p class="pm-left-foot">PeakMetrics &copy; @DateTime.Now.Year</p>
        </section>

        <section class="pm-right">
            <div class="pm-right-inner">
                <div class="pm-logo-wrap">
                    <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics" class="pm-logo-img" />
                </div>

                <h2 class="pm-form-title">Create Account</h2>
                <p class="pm-form-sub">Request access to PeakMetrics.</p>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
                {
                    <div class="pm-alert pm-shake">
                        @Html.ValidationMessage(string.Empty)
                    </div>
                }

                <form asp-controller="Account" asp-action="Register" method="post" id="registerForm">
                    @Html.AntiForgeryToken()

                    <div class="pm-field">
                        <label asp-for="FullName">Full Name</label>
                        <input asp-for="FullName" type="text" placeholder="Your full name" id="regFullName"
                               class="@(ViewData.ModelState["FullName"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <div class="pm-error">@Html.ValidationMessageFor(m => m.FullName)</div>
                    </div>

                    <div class="pm-field">
                        <label asp-for="Email">Email Address</label>
                        <input asp-for="Email" type="email" placeholder="you@company.com" id="regEmail"
                               class="@(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <div class="pm-error">@Html.ValidationMessageFor(m => m.Email)</div>
                    </div>

                    <div class="pm-row">
                        <div class="pm-field">
                            <label asp-for="Password">Password</label>
                            <input asp-for="Password" type="password" placeholder="Min. 8 characters" id="regPassword"
                                   class="@(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                            <div class="pm-error">@Html.ValidationMessageFor(m => m.Password)</div>
                        </div>
                        <div class="pm-field">
                            <label asp-for="ConfirmPassword">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" placeholder="Repeat password" id="regConfirmPassword"
                                   class="@(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                            <div class="pm-error">@Html.ValidationMessageFor(m => m.ConfirmPassword)</div>
                        </div>
                    </div>

                    <div class="pm-row">
                        <div class="pm-field">
                            <label asp-for="DepartmentId">Department</label>
                            <select asp-for="DepartmentId" id="regDepartment">
                                <option value="">— Select department —</option>
                                @foreach (var dept in departments)
                                {
                                    if (Model.DepartmentId == (int?)dept.Id)
                                    {
                                        <option value="@dept.Id" selected>@dept.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@dept.Id">@dept.Name</option>
                                    }
                                }
                            </select>
                            <div class="pm-error">@Html.ValidationMessageFor(m => m.DepartmentId)</div>
                        </div>
                        <div class="pm-field">
                            <label asp-for="PendingRole">Requested Role</label>
                            <select asp-for="PendingRole" id="regRole">
                                <option value="Staff">Staff</option>
                                <option value="Manager">Manager</option>
                            </select>
                            <div class="pm-error">@Html.ValidationMessageFor(m => m.PendingRole)</div>
                        </div>
                    </div>

                    <button type="submit" class="pm-btn pm-btn-primary" id="registerBtn">Create Account</button>
                </form>

                <p class="text-center mt-3" style="font-size:0.88rem; color:#64748b;">
                    Already have an account?
                    <a href="/Home/Login" style="color:#2563eb; font-weight:600;">Login instead</a>
                </p>

                <script>
                (function () {
                    var form        = document.getElementById('registerForm');
                    var btn         = document.getElementById('registerBtn');

                    // Re-enable button if page reloaded with server errors
                    btn.disabled = false;
                    btn.textContent = 'Create Account';

                    form.addEventListener('submit', function () {
                        btn.disabled = true;
                        btn.textContent = 'Submitting...';
                        // Re-enable after 5s in case of server error returning the view
                        setTimeout(function () {
                            btn.disabled = false;
                            btn.textContent = 'Create Account';
                        }, 5000);
                    });
                })();
                </script>
            </div>
        </section>
    </div>
</body>
</html>
