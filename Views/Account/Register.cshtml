@model PeakMetrics.Web.ViewModels.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Register";
    var departments = ViewBag.Departments as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - PeakMetrics</title>
    <link rel="icon" type="image/png" href="~/images/peakmetrics-logo.png" />
    <link rel="shortcut icon" href="~/images/peakmetrics-logo.png" />
    
    <!-- Prevent FOUC (Flash of Unstyled Content) -->
    <script>
        (function() {
            const theme = localStorage.getItem('peakmetrics-theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; }

        /* ─────────────────────────────────────────────
           ANIMATIONS
        ───────────────────────────────────────────── */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-50px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(50px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes scaleIn {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .animate-fade-in-up {
            animation: fadeInUp 0.8s ease-out forwards;
        }

        .animate-slide-in-left {
            animation: slideInLeft 0.8s ease-out forwards;
        }

        .animate-slide-in-right {
            animation: slideInRight 0.8s ease-out forwards;
        }

        .animate-scale-in {
            animation: scaleIn 0.6s ease-out forwards;
        }

        .delay-100 { animation-delay: 0.1s; }
        .delay-200 { animation-delay: 0.2s; }
        .delay-300 { animation-delay: 0.3s; }
        .delay-400 { animation-delay: 0.4s; }
        .delay-500 { animation-delay: 0.5s; }

        body {
            font-family: "Manrope", "Segoe UI", Tahoma, sans-serif;
            background: linear-gradient(135deg, var(--bg-gradient-start) 0%, var(--bg-gradient-mid) 50%, var(--bg-gradient-end) 100%);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            min-height: 100vh;
            position: relative;
            overflow: hidden;
            z-index: 0;
        }

        @@keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Animated floating shapes */
        .bg-shape {
            position: fixed;
            border-radius: 50%;
            opacity: 0.15;
            filter: blur(60px);
            animation: float-shape 20s ease-in-out infinite;
            z-index: -1;
        }

        .bg-shape-1 {
            width: 400px;
            height: 400px;
            background: linear-gradient(135deg, #1e40af, #3b82f6);
            top: -100px;
            left: -100px;
            animation-delay: 0s;
        }

        .bg-shape-2 {
            width: 350px;
            height: 350px;
            background: linear-gradient(135deg, #60a5fa, #93c5fd);
            bottom: -80px;
            right: -80px;
            animation-delay: 5s;
        }

        .bg-shape-3 {
            width: 300px;
            height: 300px;
            background: linear-gradient(135deg, #2563eb, #60a5fa);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation-delay: 10s;
        }

        @@keyframes float-shape {
            0%, 100% {
                transform: translate(0, 0) scale(1);
            }
            33% {
                transform: translate(30px, -30px) scale(1.1);
            }
            66% {
                transform: translate(-20px, 20px) scale(0.9);
            }
        }

        /* Animated icon particles */
        .particle {
            position: fixed;
            color: rgba(255, 255, 255, 0.15);
            font-size: 32px;
            animation: particle-float 20s linear infinite;
            pointer-events: none;
            z-index: -1;
        }

        @@keyframes particle-float {
            0% {
                transform: translateY(0) translateX(0) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 0.2;
            }
            50% {
                opacity: 0.18;
            }
            80% {
                opacity: 0.15;
            }
            100% {
                transform: translateY(-120vh) translateX(30px) rotate(180deg);
                opacity: 0;
            }
        }

        .pm-card {
            width: min(1080px, 100%);
            height: 620px;
            display: flex;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 30px 80px var(--card-shadow), 0 0 0 1px rgba(255, 255, 255, 0.1);
            background: var(--card-bg);
            animation: scaleIn 0.6s ease-out;
            position: relative;
            z-index: 10;
        }

        /* ── Left panel ── */
        .pm-left {
            width: 45%;
            position: relative;
            overflow: hidden;
            color: #fff;
            padding: 52px 56px;
            background: linear-gradient(145deg, #1e3a8a 0%, #1e40af 55%, #3b82f6 100%);
            display: flex;
            flex-direction: column;
        }

        .pm-left::before {
            content: "";
            position: absolute;
            width: 700px; height: 700px;
            border-radius: 50%;
            left: -160px; bottom: -400px;
            background: rgba(147, 197, 253, 0.18);
            pointer-events: none;
        }

        .pm-left::after {
            content: "";
            position: absolute;
            width: 500px; height: 500px;
            border-radius: 50%;
            right: -200px; top: -200px;
            background: rgba(147, 197, 253, 0.12);
            pointer-events: none;
        }

        .pm-left-content, .pm-left-foot { position: relative; z-index: 1; }

        .pm-kicker {
            margin: 0 0 18px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(219, 234, 254, 0.9);
        }

        .pm-headline {
            margin: 0 0 18px;
            font-size: clamp(2.4rem, 4vw, 3.6rem);
            font-weight: 800;
            line-height: 1.0;
            letter-spacing: -0.02em;
        }

        .pm-copy {
            margin: 0;
            font-size: 1rem;
            line-height: 1.5;
            color: rgba(219, 234, 254, 0.88);
            max-width: 420px;
        }

        .pm-left-foot {
            margin-top: auto;
            font-size: 0.88rem;
            color: rgba(219, 234, 254, 0.7);
        }

        /* ── Right panel ── */
        .pm-right {
            width: 55%;
            background: var(--card-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 56px;
            overflow-y: auto;
        }

        .pm-right-inner { width: 100%; max-width: 420px; }

        .pm-logo-wrap {
            text-align: center;
            margin-bottom: 12px;
        }

        .pm-logo-img {
            height: 80px;
            width: auto;
            display: block;
            margin: 0 auto;
            object-fit: contain;
        }

        .pm-form-title {
            margin: 0 0 4px;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.02em;
        }

        .pm-form-sub {
            margin: 0 0 12px;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .pm-field { margin-bottom: 12px; }

        .pm-field label {
            display: block;
            margin-bottom: 4px;
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .pm-field input,
        .pm-field select {
            width: 100%;
            border: none;
            border-bottom: 2px solid var(--input-border);
            border-radius: 0;
            background: transparent;
            padding: 7px 2px;
            font-size: 0.9rem;
            color: var(--input-text);
            outline: none;
            transition: border-color 0.2s;
            appearance: none;
            -webkit-appearance: none;
        }

        .pm-field input:focus,
        .pm-field select:focus { border-bottom-color: var(--input-border-focus); }

        .pm-field input::placeholder { color: var(--input-placeholder); }
        .pm-field input.is-invalid,
        .pm-field select.is-invalid { border-bottom-color: var(--status-error); }

        .pm-error {
            margin-top: 3px;
            font-size: 0.75rem;
            color: var(--status-error);
        }

        .pm-alert {
            padding: 8px 12px;
            border-radius: 8px;
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #b91c1c;
            font-size: 0.82rem;
            margin-bottom: 10px;
        }

        .pm-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0 16px; }

        .pm-btn {
            width: 100%;
            padding: 11px;
            border-radius: 10px;
            font-size: 0.92rem;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
        }

        .pm-btn-primary {
            background: linear-gradient(120deg, var(--btn-primary-bg) 0%, var(--btn-primary-hover) 100%);
            color: var(--btn-primary-text);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
            margin-top: 4px;
        }

        .pm-btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 24px rgba(37, 99, 235, 0.38);
        }

        @@keyframes pm-shake {
            0%, 100% { transform: translateX(0); }
            20%       { transform: translateX(-6px); }
            40%       { transform: translateX(6px); }
            60%       { transform: translateX(-4px); }
            80%       { transform: translateX(4px); }
        }

        .pm-shake { animation: pm-shake 0.4s ease; }

        @@media (max-width: 900px) {
            body { padding: 0; }
            .pm-card { flex-direction: column; height: auto; min-height: 100vh; border-radius: 0; box-shadow: none; }
            .pm-left, .pm-right { width: 100%; }
            .pm-left { padding: 36px 28px; min-height: 280px; }
            .pm-right { padding: 28px 24px 36px; align-items: flex-start; }
            .pm-row { grid-template-columns: 1fr; }
            .pm-logo-img { height: 70px; }
        }

        /* ── Terms checkbox ── */
        .pm-terms-wrap {
            margin-top: 12px;
        }

        .pm-terms-label {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            cursor: pointer;
            font-size: 0.82rem;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        .pm-terms-checkbox {
            flex-shrink: 0;
            width: 16px;
            height: 16px;
            margin-top: 2px;
            accent-color: var(--btn-primary-bg);
            cursor: pointer;
        }

        .pm-terms-link {
            color: var(--link-color);
            font-weight: 600;
            text-decoration: underline;
            text-underline-offset: 2px;
        }

        .pm-terms-link:hover {
            opacity: 0.8;
        }

        /* ── Legal modals ── */
        .pm-modal-body {
            max-height: 60vh;
            overflow-y: auto;
            font-size: 0.88rem;
            line-height: 1.7;
            color: #374151;
        }

        .pm-modal-body h6 {
            font-weight: 700;
            color: #1e3a8a;
            margin-top: 1.2rem;
            margin-bottom: 0.3rem;
            font-size: 0.9rem;
        }

        .pm-modal-body p {
            margin-bottom: 0.5rem;
        }

        .pm-modal-body ul {
            padding-left: 1.2rem;
            margin-bottom: 0.5rem;
        }
    </style>
</head>
<body>
    <!-- Animated background shapes -->
    <div class="bg-shape bg-shape-1"></div>
    <div class="bg-shape bg-shape-2"></div>
    <div class="bg-shape bg-shape-3"></div>
    
    <!-- Floating icon particles - rising like bubbles -->
    <i class="particle bi bi-graph-up" style="left: 8%; bottom: 10%; animation-delay: 0s;"></i>
    <i class="particle bi bi-bar-chart-line" style="left: 15%; bottom: 5%; animation-delay: 3s;"></i>
    <i class="particle bi bi-pie-chart" style="left: 12%; bottom: 15%; animation-delay: 6s;"></i>
    <i class="particle bi bi-graph-up-arrow" style="left: 5%; bottom: 8%; animation-delay: 2s;"></i>
    <i class="particle bi bi-bar-chart-fill" style="left: 10%; bottom: 20%; animation-delay: 5s;"></i>
    
    <i class="particle bi bi-graph-down" style="left: 88%; bottom: 12%; animation-delay: 8s;"></i>
    <i class="particle bi bi-bar-chart" style="left: 92%; bottom: 6%; animation-delay: 4s;"></i>
    <i class="particle bi bi-pie-chart-fill" style="left: 95%; bottom: 18%; animation-delay: 7s;"></i>
    <i class="particle bi bi-activity" style="left: 85%; bottom: 10%; animation-delay: 1s;"></i>
    <i class="particle bi bi-graph-up" style="left: 90%; bottom: 14%; animation-delay: 9s;"></i>
    
    <div class="pm-card">
        <section class="pm-left">
            <div class="pm-left-content">
                <p class="pm-kicker animate-fade-in-up">Analytics &amp; Insights Platform</p>
                <h1 class="pm-headline animate-fade-in-up delay-100">Join<br>PeakMetrics</h1>
                <p class="pm-copy animate-fade-in-up delay-200">Submit your request to join your organization's performance management system.</p>
            </div>
            <p class="pm-left-foot animate-fade-in-up delay-300">PeakMetrics &copy; @DateTime.Now.Year</p>
        </section>

        <section class="pm-right">
            <div class="pm-right-inner">
                <div class="pm-logo-wrap animate-scale-in">
                    <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics" class="pm-logo-img" />
                </div>

                <h2 class="pm-form-title animate-fade-in-up delay-200">Create Account</h2>
                <p class="pm-form-sub animate-fade-in-up delay-300">Request access to PeakMetrics.</p>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
                {
                    <div class="pm-alert pm-shake">
                        @Html.ValidationMessage(string.Empty)
                    </div>
                }

                <form asp-controller="Account" asp-action="Register" method="post" id="registerForm" class="animate-fade-in-up delay-400">
                    @Html.AntiForgeryToken()

                    <div class="pm-field">
                        <label asp-for="FullName">Full Name</label>
                        <input asp-for="FullName" type="text" placeholder="Your full name" id="regFullName"
                               class="@(ViewData.ModelState["FullName"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <div class="pm-error">@Html.ValidationMessageFor(m => m.FullName)</div>
                    </div>

                    <div class="pm-field">
                        <label asp-for="Email">Email Address</label>
                        <input asp-for="Email" type="email" placeholder="you@company.com" id="regEmail"
                               class="@(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <div class="pm-error">@Html.ValidationMessageFor(m => m.Email)</div>
                    </div>

                    <div class="pm-row">
                        <div class="pm-field">
                            <label asp-for="Password">Password</label>
                            <div style="position:relative;">
                                <input asp-for="Password" type="password" placeholder="Min. 8 characters" id="regPassword"
                                       style="padding-right:2.2rem;"
                                       class="@(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                                <button type="button" onclick="togglePw('regPassword',this)"
                                        style="position:absolute;right:4px;top:50%;transform:translateY(-50%);background:none;border:none;padding:4px;cursor:pointer;color:#64748b;line-height:1;"
                                        aria-label="Show password">
                                    <i class="bi bi-eye" style="font-size:1rem;"></i>
                                </button>
                            </div>
                            <div class="pm-error">@Html.ValidationMessageFor(m => m.Password)</div>
                        </div>
                        <div class="pm-field">
                            <label asp-for="ConfirmPassword">Confirm Password</label>
                            <div style="position:relative;">
                                <input asp-for="ConfirmPassword" type="password" placeholder="Repeat password" id="regConfirmPassword"
                                       style="padding-right:2.2rem;"
                                       class="@(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                                <button type="button" onclick="togglePw('regConfirmPassword',this)"
                                        style="position:absolute;right:4px;top:50%;transform:translateY(-50%);background:none;border:none;padding:4px;cursor:pointer;color:#64748b;line-height:1;"
                                        aria-label="Show password">
                                    <i class="bi bi-eye" style="font-size:1rem;"></i>
                                </button>
                            </div>
                            <div class="pm-error">@Html.ValidationMessageFor(m => m.ConfirmPassword)</div>
                        </div>
                    </div>

                    <div class="pm-field">
                        <label asp-for="DepartmentId">Department (Optional)</label>
                        <select asp-for="DepartmentId" id="regDepartment">
                            <option value="">— Select department —</option>
                            @foreach (var dept in departments)
                            {
                                if (Model.DepartmentId == (int?)dept.Id)
                                {
                                    <option value="@dept.Id" selected>@dept.Name</option>
                                }
                                else
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                        <div class="pm-error">@Html.ValidationMessageFor(m => m.DepartmentId)</div>
                    </div>

                    <button type="submit" class="pm-btn pm-btn-primary" id="registerBtn">Create Account</button>

                    <!-- Terms & Conditions checkbox -->
                    <div class="pm-terms-wrap animate-fade-in-up delay-500">
                        <label class="pm-terms-label">
                            <input type="checkbox" asp-for="AgreeToTerms" id="agreeToTerms" class="pm-terms-checkbox" />
                            <span>
                                I have read and agree to the
                                <a href="#" class="pm-terms-link" data-bs-toggle="modal" data-bs-target="#termsModal">Terms and Conditions</a>
                                and
                                <a href="#" class="pm-terms-link" data-bs-toggle="modal" data-bs-target="#privacyModal">Privacy Policy</a>.
                            </span>
                        </label>
                        <div class="pm-error" id="termsError">@Html.ValidationMessageFor(m => m.AgreeToTerms)</div>
                    </div>
                </form>

                <p class="text-center mt-3 animate-fade-in-up delay-500" style="font-size:0.88rem; color:var(--text-secondary);">
                    Already have an account?
                    <a href="/Home/Login" style="color:var(--link-color); font-weight:600;">Login instead</a>
                </p>

                <script>
                function togglePw(id, btn) {
                    var input = document.getElementById(id);
                    var icon = btn.querySelector('i');
                    if (input.type === 'password') {
                        input.type = 'text';
                        icon.className = 'bi bi-eye-slash';
                        btn.setAttribute('aria-label', 'Hide password');
                    } else {
                        input.type = 'password';
                        icon.className = 'bi bi-eye';
                        btn.setAttribute('aria-label', 'Show password');
                    }
                }
                (function () {
                    var form        = document.getElementById('registerForm');
                    var btn         = document.getElementById('registerBtn');
                    var termsBox    = document.getElementById('agreeToTerms');
                    var termsErr    = document.getElementById('termsError');

                    // Re-enable button if page reloaded with server errors
                    btn.disabled = false;
                    btn.textContent = 'Create Account';

                    termsBox.addEventListener('change', function () {
                        if (termsBox.checked) {
                            termsErr.textContent = '';
                            termsBox.classList.remove('is-invalid');
                        }
                    });

                    form.addEventListener('submit', function (e) {
                        if (!termsBox.checked) {
                            e.preventDefault();
                            termsErr.textContent = 'You must agree to the Terms and Conditions and Privacy Policy.';
                            termsBox.classList.add('is-invalid');
                            form.classList.add('pm-shake');
                            setTimeout(function () { form.classList.remove('pm-shake'); }, 500);
                            return;
                        }
                        btn.disabled = true;
                        btn.textContent = 'Submitting...';
                        // Re-enable after 5s in case of server error returning the view
                        setTimeout(function () {
                            btn.disabled = false;
                            btn.textContent = 'Create Account';
                        }, 5000);
                    });
                })();
                </script>
            </div>
        </section>
    </div>

    <!-- ── Terms and Conditions Modal ── -->
    <div class="modal fade" id="termsModal" tabindex="-1" aria-labelledby="termsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
            <div class="modal-content">
                <div class="modal-header" style="background:linear-gradient(135deg,#1e3a8a,#3b82f6);color:#fff;">
                    <h5 class="modal-title fw-bold" id="termsModalLabel">
                        <i class="bi bi-file-earmark-text me-2"></i>Terms and Conditions
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pm-modal-body">
                    <p><strong>System Name:</strong> PeakMetrics &nbsp;|&nbsp; <strong>Effective Date:</strong> 2026</p>

                    <h6>1. Acceptance of Terms</h6>
                    <p>By registering for and using PeakMetrics, you agree to be bound by these Terms and Conditions. If you do not agree to these terms, you may not access or use the system. Your continued use of PeakMetrics constitutes your acceptance of any updates to these terms.</p>

                    <h6>2. User Responsibilities</h6>
                    <p>As a registered user of PeakMetrics, you agree to:</p>
                    <ul>
                        <li>Provide accurate, current, and complete information during registration.</li>
                        <li>Use the system solely for legitimate organizational performance management purposes.</li>
                        <li>Comply with all applicable laws, regulations, and organizational policies.</li>
                        <li>Promptly notify your administrator of any unauthorized use of your account.</li>
                        <li>Not share your login credentials with any other person.</li>
                    </ul>

                    <h6>3. Account Security</h6>
                    <p>You are responsible for maintaining the confidentiality of your account credentials. PeakMetrics implements security measures including account lockout after repeated failed login attempts, session timeouts, and encrypted password storage. You must immediately report any suspected unauthorized access to your account to your system administrator.</p>

                    <h6>4. Data Privacy</h6>
                    <p>PeakMetrics collects and processes personal data as described in our Privacy Policy. By using the system, you consent to the collection and use of your information in accordance with the Privacy Policy. We are committed to protecting your personal data and will not sell or share it with third parties except as required by law.</p>

                    <h6>5. Prohibited Activities</h6>
                    <p>Users are strictly prohibited from:</p>
                    <ul>
                        <li>Attempting to gain unauthorized access to other user accounts or system resources.</li>
                        <li>Uploading or transmitting malicious code, viruses, or harmful content.</li>
                        <li>Using the system to harass, intimidate, or harm other users.</li>
