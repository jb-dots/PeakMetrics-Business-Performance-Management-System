@model IReadOnlyList<PeakMetrics.Web.ViewModels.AuditLogEntryViewModel>
@{
    var entries = Model ?? Array.Empty<PeakMetrics.Web.ViewModels.AuditLogEntryViewModel>();

    // Distinct values for filter dropdowns
    var actions  = entries.Select(e => e.Action).Distinct().OrderBy(x => x).ToList();
    var entities = entries.Select(e => e.EntityType).Distinct().OrderBy(x => x).ToList();
}

<div class="card card-clean mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-funnel text-muted"></i>
            <h6 class="mb-0 fw-semibold">Filters</h6>
        </div>
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label small fw-semibold">Action Type</label>
                <select class="form-select" id="auditActionFilter">
                    <option value="All">All</option>
                    @foreach (var a in actions)
                    {
                        <option value="@a">@a</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label small fw-semibold">Entity Type</label>
                <select class="form-select" id="auditEntityFilter">
                    <option value="All">All</option>
                    @foreach (var e in entities)
                    {
                        <option value="@e">@e</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card card-clean">
    <div class="card-body">
        @if (!entries.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-shield-lock fs-1 d-block mb-3 opacity-25"></i>
                <h5 class="fw-semibold">No audit entries yet</h5>
                <p class="mb-0 small">Every action in the system — logins, KPI logs, edits — will appear here automatically.</p>
            </div>
        }
        else
        {
            <div class="table-responsive table-scrollable">
                <table class="table table-hover mb-0" id="auditTable" style="font-size:0.875rem;">
                    <thead>
                        <tr>
                            <th class="table-sortable" data-sort-type="date">Timestamp</th>
                            <th class="table-sortable" data-sort-type="text">User</th>
                            <th class="table-sortable" data-sort-type="text">Action</th>
                            <th class="table-sortable" data-sort-type="text">Entity Type</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in entries)
                        {
                            var nameParts = entry.UserName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                            var initials  = nameParts.Length >= 2
                                ? $"{nameParts[0][0]}{nameParts[^1][0]}"
                                : entry.UserName[..Math.Min(2, entry.UserName.Length)];

                            var actionCss = entry.Action.Contains("Login")   ? "status-badge status-ontrack"
                                          : entry.Action.Contains("Logout")  ? "status-badge bg-light text-secondary border"
                                          : entry.Action.Contains("Created") ? "status-badge status-ontrack"
                                          : entry.Action.Contains("Deleted") ? "status-badge status-behind"
                                          : "status-badge status-atrisk";

                            <tr data-action="@entry.Action" data-entity="@entry.EntityType">
                                <td class="text-muted" style="font-family:monospace;white-space:nowrap;font-size:0.8rem;">
                                    @entry.Timestamp
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-semibold flex-shrink-0"
                                             style="width:28px;height:28px;background:#1B4FD8;font-size:0.7rem;">
                                            @initials.ToUpperInvariant()
                                        </div>
                                        <span>@entry.UserName</span>
                                    </div>
                                </td>
                                <td><span class="@actionCss">@entry.Action</span></td>
                                <td><span class="badge text-dark border" style="background:#f3f4f6;">@entry.EntityType</span></td>
                                <td class="text-muted" style="max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                    title="@entry.Details">
                                    @entry.Details
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer-meta">
                <div class="table-footer-tools">
                    <label for="auditPageSize" class="small text-muted mb-0">Rows</label>
                    <select class="form-select form-select-sm table-page-size-select" id="auditPageSize">
                        <option value="10">10</option>
                        <option value="25" selected>25</option>
                        <option value="50">50</option>
                    </select>
                    <div class="btn-group btn-group-sm table-density-toggle" id="auditDensityToggle" role="group">
                        <button type="button" class="btn btn-outline-secondary active" data-density="comfortable">Comfortable</button>
                        <button type="button" class="btn btn-outline-secondary" data-density="compact">Compact</button>
                    </div>
                </div>
                <small class="text-muted" id="auditTableSummary"></small>
                <div class="table-pagination" id="auditTablePagination"></div>
            </div>
        }
    </div>
</div>
