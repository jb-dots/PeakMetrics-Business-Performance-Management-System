@model PeakMetrics.Web.ViewModels.BalancedScorecardViewModel

@{
    var perspectiveColors = new Dictionary<string, string>
    {
        ["Financial"]        = "#1B4FD8",
        ["Customer"]         = "#0891b2",
        ["Internal Process"] = "#7c3aed",
        ["Learning & Growth"]= "#059669"
    };
}

@if (!Model.Perspectives.Any())
{
    <div class="card card-clean">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-grid-3x3-gap fs-1 d-block mb-3 opacity-25"></i>
            <h5 class="fw-semibold">No scorecard data yet</h5>
            <p class="mb-3 small">KPIs are defined but no actual values have been logged yet.</p>
            <a asp-controller="Home" asp-action="KPILogEntry" class="btn btn-primary-custom btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Log First Entry
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var group in Model.Perspectives)
        {
            var color = perspectiveColors.TryGetValue(group.Perspective, out var c) ? c : "#1B4FD8";
            <div class="col-12 col-lg-6">
                <div class="card card-clean h-100 overflow-hidden">
                    <div class="text-white fw-semibold d-flex align-items-center gap-2"
                         style="background:@color;padding:1rem 1.5rem;font-size:1rem;">
                        <i class="bi bi-grid-3x3-gap"></i>
                        @group.Perspective
                        <span class="ms-auto badge bg-white bg-opacity-25 rounded-pill" style="font-size:0.75rem;">
                            @group.Kpis.Count KPI@(group.Kpis.Count == 1 ? "" : "s")
                        </span>
                    </div>
                    <div class="card-body p-4 d-flex flex-column gap-3">
                        @if (!group.Kpis.Any())
                        {
                            <p class="text-muted small mb-0">No KPIs in this perspective.</p>
                        }
                        else
                        {
                            @foreach (var kpi in group.Kpis)
                            {
                                var statusCss = kpi.Status switch
                                {
                                    "On Track" => "status-badge status-ontrack",
                                    "At Risk"  => "status-badge status-atrisk",
                                    "Behind"   => "status-badge status-behind",
                                    _          => "status-badge bg-light text-secondary border"
                                };
                                <div class="border rounded-3 p-3" style="background:#f9fafb;">
                                    <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                        <h6 class="mb-0 fw-semibold" style="font-size:0.88rem;">@kpi.Name</h6>
                                        <span class="@statusCss flex-shrink-0">@kpi.Status</span>
                                    </div>
                                    <div class="d-flex gap-4" style="font-size:0.82rem;">
                                        <div><span class="text-muted">Target: </span><span class="fw-semibold">@kpi.Target</span></div>
                                        <div><span class="text-muted">Actual: </span><span class="fw-bold">@kpi.Actual</span></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
