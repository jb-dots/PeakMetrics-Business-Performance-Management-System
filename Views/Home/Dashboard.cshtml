@model object
@using PeakMetrics.Web.ViewModels

@if (Model is SuperAdminDashboardViewModel superAdmin)
{
    <partial name="_SuperAdminDashboard" model="superAdmin" />
}
else if (Model is AdministratorDashboardViewModel admin)
{
    <partial name="_AdministratorDashboard" model="admin" />
}
else if (Model is ManagerDashboardViewModel manager)
{
    <partial name="_ManagerDashboard" model="manager" />
}
else if (Model is StaffDashboardViewModel staff)
{
    <partial name="_StaffDashboard" model="staff" />
}
else if (Model is ExecutiveDashboardViewModel executive)
{
    <partial name="_ExecutiveDashboard" model="executive" />
}
