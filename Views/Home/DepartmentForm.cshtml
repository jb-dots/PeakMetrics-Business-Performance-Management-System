@model PeakMetrics.Web.ViewModels.DepartmentFormViewModel
@{
    var isEdit = Model.Id > 0;
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-6">
        <div class="card card-clean">
            <div class="card-body p-4">
                <h5 class="card-title mb-1">@(isEdit ? "Edit Department" : "Add Department")</h5>
                <p class="text-muted small mb-4">
                    @(isEdit
                        ? "Update the department name or description."
                        : "Create a new department. Users and KPIs can be assigned to it after creation.")
                </p>

                <form asp-controller="Home"
                      asp-action="@(isEdit ? "DepartmentEdit" : "DepartmentCreate")"
                      method="post">
                    @Html.AntiForgeryToken()
                    @if (isEdit)
                    {
                        <input type="hidden" asp-for="Id" />
                    }

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Department Name</label>
                        <input asp-for="Name" class="form-control @(ViewData.ModelState["Name"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="e.g., Finance" autofocus />
                        <div class="invalid-feedback">@Html.ValidationMessageFor(m => m.Name)</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold">
                            Description <span class="text-muted fw-normal">(optional, supports Markdown)</span>
                        </label>
                        <textarea asp-for="Description" class="form-control markdown-editor @(ViewData.ModelState["Description"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                  rows="4" placeholder="Brief description of this department's function... (Markdown supported)"></textarea>
                        <small class="text-muted">
                            <i class="bi bi-markdown me-1"></i>
                            Supports **bold**, *italic*, lists, links, and more
                        </small>
                        <div class="invalid-feedback">@Html.ValidationMessageFor(m => m.Description)</div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-controller="Home" asp-action="DepartmentManagement"
                           class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary-custom d-inline-flex align-items-center gap-2">
                            <i class="bi bi-floppy"></i>
                            @(isEdit ? "Save Changes" : "Add Department")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<link rel="stylesheet" href="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.css">
<script src="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.js"></script>
<script>
(function() {
    var textarea = document.querySelector('.markdown-editor');
    if (textarea) {
        var simplemde = new SimpleMDE({
            element: textarea,
            spellChecker: false,
            placeholder: "Brief description of this department's function... (Markdown supported)",
            status: false,
            toolbar: [
                "bold", "italic", "heading", "|",
                "quote", "unordered-list", "ordered-list", "|",
                "link", "preview", "|",
                "guide"
            ]
        });
    }
})();
</script>
}
