@model PeakMetrics.Web.ViewModels.DepartmentManagementViewModel

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-check-circle-fill"></i>
        <span>@Html.Raw(successMsg)</span>
    </div>
}
@if (TempData["ErrorMessage"] is string errorMsg)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@Html.Raw(errorMsg)</span>
    </div>
}

<div class="card card-clean mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-md-8">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute" style="left:12px;top:50%;transform:translateY(-50%);color:#6b7280;"></i>
                    <input type="text" class="form-control ps-5" id="departmentSearch" placeholder="Search departments..." />
                </div>
            </div>
            <div class="col-12 col-md-4">
                <a asp-controller="Home" asp-action="DepartmentCreate"
                   class="btn btn-primary-custom w-100 d-inline-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-plus-lg"></i> Add Department
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card card-clean">
    <div class="card-body">
        @if (!Model.Departments.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-building fs-1 d-block mb-3 opacity-25"></i>
                <h5 class="fw-semibold">No departments yet</h5>
                <p class="mb-3 small">Add your first department to start organizing users and KPIs.</p>
                <a asp-controller="Home" asp-action="DepartmentCreate" class="btn btn-primary-custom btn-sm">
                    <i class="bi bi-plus-lg me-1"></i> Add Department
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="departmentTable">
                    <thead class="table-light">
                        <tr>
                            <th>Department Name</th>
                            <th>Description</th>
                            <th class="text-center">Users</th>
                            <th class="text-center">Active KPIs</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dept in Model.Departments)
                        {
                            <tr data-search="@($"{dept.Name} {dept.Description}")">
                                <td class="fw-semibold">@dept.Name</td>
                                <td class="text-muted small">@(dept.Description ?? "—")</td>
                                <td class="text-center">
                                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle fw-semibold"
                                          style="width:32px;height:32px;background:#eff6ff;color:#1B4FD8;font-size:0.85rem;">
                                        @dept.UserCount
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle fw-semibold"
                                          style="width:32px;height:32px;background:#eff6ff;color:#1B4FD8;font-size:0.85rem;">
                                        @dept.KpiCount
                                    </span>
                                </td>
                                <td class="text-muted small">@dept.CreatedAt</td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-controller="Home" asp-action="DepartmentEdit" asp-route-id="@dept.Id"
                                           class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        @if (dept.UserCount == 0 && dept.KpiCount == 0)
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    title="Delete"
                                                    data-dept-id="@dept.Id"
                                                    data-dept-name="@dept.Name"
                                                    onclick="confirmDeleteDept(this)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                                    title="Cannot delete — has users or KPIs assigned" disabled>
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div id="noDepartmentResults" class="text-center text-muted py-4" style="display:none;">
                No departments found matching your search.
            </div>
        }
    </div>
</div>

<!-- Delete confirmation modal -->
<div class="modal fade" id="deleteDeptModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content logout-modal-content">
            <div class="logout-modal-icon" style="background:#fef2f2;">
                <i class="bi bi-trash" style="color:#ef4444;"></i>
            </div>
            <h5 class="logout-modal-title">Delete Department?</h5>
            <p class="logout-modal-body">
                Delete <strong id="deleteDeptName"></strong>? This cannot be undone.
            </p>
            <div class="logout-modal-actions">
                <button type="button" class="btn logout-cancel-btn" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteDeptForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn logout-confirm-btn">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function confirmDeleteDept(btn) {
    var id   = btn.getAttribute('data-dept-id');
    var name = btn.getAttribute('data-dept-name');
    document.getElementById('deleteDeptName').textContent = name;
    document.getElementById('deleteDeptForm').action = '/Home/DepartmentDelete/' + id;
    new bootstrap.Modal(document.getElementById('deleteDeptModal')).show();
}
</script>
}
