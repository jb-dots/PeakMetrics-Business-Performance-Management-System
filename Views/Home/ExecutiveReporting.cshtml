@model PeakMetrics.Web.ViewModels.ExecutiveReportingViewModel

<div class="card card-clean mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold" for="reportPeriodSelect">Reporting Period</label>
                <select class="form-select" id="reportPeriodSelect">
                    @if (!Model.AvailablePeriods.Any())
                    {
                        <option value="">No data yet</option>
                    }
                    else
                    {
                        @foreach (var period in Model.AvailablePeriods)
                        {
                            var sel = period == Model.SelectedPeriod;
                            <option value="@period" selected="@(sel ? "selected" : null)">@period</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-6">
                <fieldset class="d-flex gap-3 flex-wrap" style="border:none;padding:0;margin:0;">
                    <legend class="form-label small fw-semibold mb-1 w-100">Include Sections</legend>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="includeScorecard" checked />
                        <label class="form-check-label" for="includeScorecard">Scorecard</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="includeKPIs" checked />
                        <label class="form-check-label" for="includeKPIs">KPIs</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="includeGoals" checked />
                        <label class="form-check-label" for="includeGoals">Goals</label>
                    </div>
                </fieldset>
            </div>
            <div class="col-12 col-md-3">
                <button class="btn btn-primary-custom w-100" id="generateExecutiveReport">
                    <i class="bi bi-printer me-2"></i>Generate Report
                </button>
            </div>
        </div>
    </div>
</div>

@if (!Model.Kpis.Any() && !Model.Goals.Any())
{
    <div class="card card-clean">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-file-earmark-text fs-1 d-block mb-3 opacity-25"></i>
            <h5 class="fw-semibold">No report data yet</h5>
            <p class="mb-3 small">Log KPI entries and create strategic goals to generate an executive report.</p>
            <a asp-controller="Home" asp-action="KPILogEntry" class="btn btn-primary-custom btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Log KPI Entry
            </a>
        </div>
    </div>
}
else
{
    <!-- Report preview -->
    <div class="card card-clean" id="report-preview">
        <div class="card-body p-4 p-lg-5">

            <!-- Header -->
            <div class="text-center border-bottom pb-4 mb-4">
                <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics" class="report-logo-image mb-2"
                     id="reportLogoImg" />
                <h4 class="fw-semibold mb-1">Executive Performance Report</h4>
                @if (!string.IsNullOrEmpty(Model.SelectedPeriod))
                {
                    <p class="text-muted mb-0">Period: @Model.SelectedPeriod</p>
                }
            </div>

            <!-- Summary cards -->
            <div class="mb-4">
                <h5 class="fw-semibold mb-3">Performance Summary</h5>
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded bg-light text-center">
                            <div class="small text-muted">Overall Score</div>
                            <div class="fs-3 fw-bold text-primary">@Model.OverallPct%</div>
                            <div class="small text-muted">On Track</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded bg-light text-center">
                            <div class="small text-muted">Total KPIs</div>
                            <div class="fs-3 fw-bold">@Model.TotalKpis</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="p-3 rounded text-center" style="background:#f0fdf4;">
                            <div class="small text-success">On Track</div>
                            <div class="fs-3 fw-bold text-success">@Model.OnTrack</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="p-3 rounded text-center" style="background:#fffbeb;">
                            <div class="small text-warning">At Risk</div>
                            <div class="fs-3 fw-bold" style="color:#d97706;">@Model.AtRisk</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="p-3 rounded text-center" style="background:#fef2f2;">
                            <div class="small text-danger">Behind</div>
                            <div class="fs-3 fw-bold text-danger">@Model.Behind</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- KPI table -->
            <div class="mb-4" id="execSectionKPIs">
                <h5 class="fw-semibold mb-3">Key Performance Indicators</h5>
                @if (!Model.Kpis.Any())
                {
                    <p class="text-muted small">No KPI data available.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>KPI Name</th>
                                    <th>Department</th>
                                    <th>Target</th>
                                    <th>Actual</th>
                                    <th>Variance</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kpi in Model.Kpis)
                                {
                                    <tr>
                                        <td class="fw-semibold">@kpi.Name</td>
                                        <td class="text-muted">@kpi.Department</td>
                                        <td>@kpi.Target</td>
                                        <td class="fw-semibold">@kpi.Actual</td>
                                        <td class="text-muted">@kpi.Variance</td>
                                        <td>@await Html.PartialAsync("_StatusBadge", kpi.Status)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- Scorecard summary -->
            <div class="mb-4" id="execSectionScorecard">
                <h5 class="fw-semibold mb-3">Balanced Scorecard Summary</h5>
                @if (!Model.Scorecards.Any())
                {
                    <p class="text-muted small">No scorecard data available.</p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var sc in Model.Scorecards)
                        {
                            <div class="col-6 col-md-3">
                                <div class="p-3 rounded bg-light">
                                    <div class="small text-muted mb-2 fw-semibold">@sc.Perspective</div>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <span class="status-badge status-ontrack">@sc.OnTrack On Track</span>
                                        @if (sc.AtRisk > 0)
                                        {
                                            <span class="status-badge status-atrisk">@sc.AtRisk At Risk</span>
                                        }
                                        @if (sc.Behind > 0)
                                        {
                                            <span class="status-badge status-behind">@sc.Behind Behind</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Strategic goals -->
            <div id="execSectionGoals">
                <h5 class="fw-semibold mb-3">Strategic Goals</h5>
                @if (!Model.Goals.Any())
                {
                    <p class="text-muted small">No strategic goals defined yet.</p>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var goal in Model.Goals)
                        {
                            var statusCss = goal.Status switch
                            {
                                "In Progress" => "status-badge status-ontrack",
                                "Completed"   => "status-badge status-ontrack",
                                "Not Started" => "status-badge bg-light text-secondary border",
                                _             => "status-badge bg-light text-secondary border"
                            };
                            <div class="p-3 rounded bg-light d-flex justify-content-between align-items-center gap-3">
                                <div>
                                    <span class="fw-semibold">@goal.Title</span>
                                    @if (goal.TargetYear.HasValue)
                                    {
                                        <span class="text-muted small ms-2">Target: @goal.TargetYear</span>
                                    }
                                </div>
                                <span class="@statusCss flex-shrink-0">@goal.Status</span>
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    </div>
}

@section Scripts {
<script>
(function () {
    var logo = document.getElementById('reportLogoImg');
    if (logo) {
        logo.addEventListener('error', function () {
            this.style.display = 'none';
        });
    }
})();
</script>
}
