@model KpiTrackingPageViewModel

@{
    var kpis = Model?.Kpis ?? Array.Empty<KpiTrackingItemViewModel>();
}

<div class="alert @(Model?.IsFallback == true ? "alert-warning" : "alert-primary") d-flex justify-content-between align-items-center gap-2 mb-4">
    <span>@(Model?.DataMessage ?? "Live KPI feed initialized.")</span>
    @if (Model?.IsFallback == true)
    {
        <a asp-controller="Home" asp-action="KPITracking" asp-route-refresh="true" class="btn btn-sm btn-outline-warning api-retry-btn">Retry Sync</a>
    }
</div>

<div class="card card-clean mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-funnel text-muted"></i>
                <h6 class="mb-0 fw-semibold">Filters</h6>
            </div>
            <a asp-controller="Home" asp-action="KPILogEntry" class="btn btn-sm btn-primary-custom d-inline-flex align-items-center gap-2">
                <i class="bi bi-plus-lg"></i>
                Log Entry
            </a>
        </div>
        <form method="get" asp-controller="Home" asp-action="KPITracking" class="row g-3" id="kpiServerFilterForm">
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold small">Department</label>
                <select class="form-select" id="kpiDepartmentFilter" name="department">
                    <option value="All" selected="@(Model?.SelectedDepartment == "All" ? "selected" : null)">All</option>
                    @foreach (var department in Model?.Departments ?? Array.Empty<string>())
                    {
                        <option value="@department" selected="@(Model?.SelectedDepartment == department ? "selected" : null)">@department</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold small">Perspective</label>
                <select class="form-select" id="kpiPerspectiveFilter" name="perspective">
                    <option value="All" selected="@(Model?.SelectedPerspective == "All" ? "selected" : null)">All</option>
                    @foreach (var perspective in Model?.Perspectives ?? Array.Empty<string>())
                    {
                        <option value="@perspective" selected="@(Model?.SelectedPerspective == perspective ? "selected" : null)">@perspective</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold small">Status</label>
                <select class="form-select" id="kpiStatusFilter" name="status">
                    <option value="All" selected="@(Model?.SelectedStatus == "All" ? "selected" : null)">All</option>
                    <option value="On Track" selected="@(Model?.SelectedStatus == "On Track" ? "selected" : null)">On Track</option>
                    <option value="At Risk" selected="@(Model?.SelectedStatus == "At Risk" ? "selected" : null)">At Risk</option>
                    <option value="Behind" selected="@(Model?.SelectedStatus == "Behind" ? "selected" : null)">Behind</option>
                </select>
            </div>
            <div class="col-12 col-md-3 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary-custom w-100">Apply Filters</button>
                <a asp-controller="Home" asp-action="KPITracking" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card card-clean">
    <div class="card-body">
        <div class="table-responsive table-scrollable">
            <table class="table table-hover mb-0" id="kpiTrackingTable">
                <thead>
                    <tr>
                        <th class="table-sortable" data-sort-type="text">KPI Name</th>
                        <th class="table-sortable" data-sort-type="text">Department</th>
                        <th class="table-sortable" data-sort-type="text">Perspective</th>
                        <th class="table-sortable" data-sort-type="text">Target Value</th>
                        <th class="table-sortable" data-sort-type="text">Actual Value</th>
                        <th class="table-sortable" data-sort-type="text">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kpi in kpis)
                    {
                        var statusClass = kpi.Severity == AlertSeverity.Critical
                            ? "status-badge status-behind"
                            : kpi.Severity == AlertSeverity.Warning
                                ? "status-badge status-atrisk"
                                : "status-badge status-ontrack";
                        <tr data-department="@kpi.Department" data-perspective="@kpi.Perspective" data-status="@kpi.Status">
                            <td class="fw-semibold">@kpi.Name</td>
                            <td>@kpi.Department</td>
                            <td>@kpi.Perspective</td>
                            <td>@kpi.Target</td>
                            <td class="fw-semibold">@kpi.Actual</td>
                            <td><span class="@statusClass">@kpi.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="table-footer-meta">
            <div class="table-footer-tools">
                <label for="kpiPageSize" class="small text-muted mb-0">Rows</label>
                <select class="form-select form-select-sm table-page-size-select" id="kpiPageSize" aria-label="Rows per page for KPI table">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                </select>
                <div class="btn-group btn-group-sm table-density-toggle" id="kpiDensityToggle" role="group" aria-label="KPI table density">
                    <button type="button" class="btn btn-outline-secondary active" data-density="comfortable">Comfortable</button>
                    <button type="button" class="btn btn-outline-secondary" data-density="compact">Compact</button>
                </div>
            </div>
            <small class="text-muted" id="kpiTableSummary"></small>
            <div class="table-pagination" id="kpiTablePagination"></div>
        </div>
    </div>
</div>
