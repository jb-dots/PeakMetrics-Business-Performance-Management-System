@model KpiTrackingPageViewModel
@{
    var kpis = Model?.Kpis ?? Array.Empty<KpiTrackingItemViewModel>();
    var role = ViewData["SessionUserRole"]?.ToString() ?? string.Empty;
    var canManage = role is "Super Admin" or "Administrator" or "Manager";
    var showArchived = (bool)(ViewBag.ShowArchived ?? false);
}

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-check-circle-fill"></i>
        <span>@successMsg</span>
    </div>
}

<div class="card card-clean mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-funnel text-muted"></i>
                <h6 class="mb-0 fw-semibold">Filters</h6>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <div class="d-flex gap-2">
                    <a asp-controller="Home" asp-action="KPITracking" asp-route-showArchived="false"
                       class="btn btn-sm @(!showArchived ? "btn-primary-custom" : "btn-outline-secondary")">
                        <i class="bi bi-bullseye me-1"></i> Active
                    </a>
                    <a asp-controller="Home" asp-action="KPITracking" asp-route-showArchived="true"
                       class="btn btn-sm @(showArchived ? "btn-primary-custom" : "btn-outline-secondary")">
                        <i class="bi bi-archive me-1"></i> Archived
                    </a>
                </div>
                @if (canManage && !showArchived)
                {
                    <a asp-controller="Home" asp-action="KpiCreate"
                       class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1">
                        <i class="bi bi-plus-lg"></i> New KPI
                    </a>
                }
                @if (!showArchived)
                {
                    <a asp-controller="Home" asp-action="KPILogEntry"
                       class="btn btn-sm btn-primary-custom d-inline-flex align-items-center gap-1">
                        <i class="bi bi-pencil-square"></i> Log Entry
                    </a>
                }
            </div>
        </div>
        <form method="get" asp-controller="Home" asp-action="KPITracking" class="row g-3">
            <input type="hidden" name="showArchived" value="@showArchived" />
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold small">Department</label>
                <select class="form-select" name="department">
                    <option value="All" selected="@(Model?.SelectedDepartment == "All" ? "selected" : null)">All</option>
                    @foreach (var dept in Model?.Departments ?? Array.Empty<string>())
                    {
                        <option value="@dept" selected="@(Model?.SelectedDepartment == dept ? "selected" : null)">@dept</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold small">Perspective</label>
                <select class="form-select" name="perspective">
                    <option value="All" selected="@(Model?.SelectedPerspective == "All" ? "selected" : null)">All</option>
                    @foreach (var persp in Model?.Perspectives ?? Array.Empty<string>())
                    {
                        <option value="@persp" selected="@(Model?.SelectedPerspective == persp ? "selected" : null)">@persp</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold small">Status</label>
                <select class="form-select" name="status">
                    <option value="All"      selected="@(Model?.SelectedStatus == "All"      ? "selected" : null)">All</option>
                    <option value="On Track" selected="@(Model?.SelectedStatus == "On Track" ? "selected" : null)">On Track</option>
                    <option value="At Risk"  selected="@(Model?.SelectedStatus == "At Risk"  ? "selected" : null)">At Risk</option>
                    <option value="Behind"   selected="@(Model?.SelectedStatus == "Behind"   ? "selected" : null)">Behind</option>
                    <option value="No Data"  selected="@(Model?.SelectedStatus == "No Data"  ? "selected" : null)">No Data</option>
                </select>
            </div>
            <div class="col-12 col-md-3 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary-custom w-100">Apply</button>
                <a asp-controller="Home" asp-action="KPITracking" asp-route-showArchived="@showArchived"
                   class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card card-clean">
    <div class="card-body">
        @if (!kpis.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi @(showArchived ? "bi-archive" : "bi-bullseye") fs-1 d-block mb-3 opacity-25"></i>
                <h6 class="fw-semibold">@(showArchived ? "No archived KPIs" : "No KPI entries yet")</h6>
                <p class="mb-3 small">
                    @(showArchived
                        ? "Archived KPIs will appear here."
                        : "KPIs are set up in the database. Log actual values to see them tracked here.")
                </p>
                @if (!showArchived)
                {
                    <a asp-controller="Home" asp-action="KPILogEntry" class="btn btn-primary-custom btn-sm">
                        <i class="bi bi-plus-lg me-1"></i> Log First Entry
                    </a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive table-scrollable">
                <table class="table table-hover mb-0" id="kpiTrackingTable">
                    <thead>
                        <tr>
                            <th class="table-sortable" data-sort-type="text">KPI Name</th>
                            <th class="table-sortable" data-sort-type="text">Department</th>
                            <th class="table-sortable" data-sort-type="text">Perspective</th>
                            <th class="table-sortable" data-sort-type="text">Target</th>
                            <th class="table-sortable" data-sort-type="text">Actual</th>
                            <th class="table-sortable" data-sort-type="text">Status</th>
                            @if (canManage)
                            {
                                <th class="text-end">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kpi in kpis)
                        {
                            var statusClass = kpi.Severity == AlertSeverity.Critical ? "status-badge status-behind"
                                            : kpi.Severity == AlertSeverity.Warning  ? "status-badge status-atrisk"
                                            : kpi.Status == "No Data"                ? "status-badge bg-light text-secondary"
                                            : "status-badge status-ontrack";
                            <tr class="@(kpi.IsArchived ? "text-muted" : "")">
                                <td class="fw-semibold">
                                    @kpi.Name
                                    @if (kpi.IsArchived)
                                    {
                                        <span class="badge bg-secondary ms-1" style="font-size:0.65rem;">Archived</span>
                                    }
                                </td>
                                <td>@kpi.Department</td>
                                <td>@kpi.Perspective</td>
                                <td>@kpi.Target</td>
                                <td class="fw-semibold">@kpi.Actual</td>
                                <td><span class="@statusClass">@kpi.Status</span></td>
                                @if (canManage)
                                {
                                    <td class="text-end">
                                        <div class="d-flex gap-1 justify-content-end">
                                            @if (!kpi.IsArchived)
                                            {
                                                <a asp-controller="Home" asp-action="KPILogEntry" asp-route-kpiId="@kpi.Id"
                                                   class="btn btn-sm btn-primary-custom d-inline-flex align-items-center gap-1" title="Log entry for this KPI">
                                                    <i class="bi bi-pencil-square"></i> Log
                                                </a>
                                                <a asp-controller="Home" asp-action="KpiEdit" asp-route-id="@kpi.Id"
                                                   class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1" title="Edit KPI definition">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </a>
                                                <form asp-controller="Home" asp-action="KpiToggleActive" asp-route-id="@kpi.Id"
                                                      method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-archive d-inline-flex align-items-center gap-1" title="Archive">
                                                        <i class="bi bi-archive"></i> Archive
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-controller="Home" asp-action="KpiToggleActive" asp-route-id="@kpi.Id"
                                                      method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-success d-inline-flex align-items-center gap-1" title="Restore">
                                                        <i class="bi bi-arrow-counterclockwise"></i> Restore
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer-meta">
                <div class="table-footer-tools">
                    <label for="kpiPageSize" class="small text-muted mb-0">Rows</label>
                    <select class="form-select form-select-sm table-page-size-select" id="kpiPageSize">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                    </select>
                    <div class="btn-group btn-group-sm table-density-toggle" id="kpiDensityToggle">
                        <button type="button" class="btn btn-outline-secondary active" data-density="comfortable">Comfortable</button>
                        <button type="button" class="btn btn-outline-secondary" data-density="compact">Compact</button>
                    </div>
                </div>
                <small class="text-muted" id="kpiTableSummary"></small>
                <div class="table-pagination" id="kpiTablePagination"></div>
            </div>
        }
    </div>
</div>
