@model PeakMetrics.Web.ViewModels.KpiManagementListViewModel
@{
    var kpis = Model?.Kpis ?? Array.Empty<PeakMetrics.Web.ViewModels.KpiManagementItemViewModel>();
}

@if (TempData["SuccessMessage"] is string msg)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-check-circle-fill"></i>
        <span>@Html.Raw(msg)</span>
    </div>
}

<div class="card card-clean">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h5 class="mb-0 fw-semibold">KPI Definitions</h5>
                <p class="text-muted small mb-0">Create and manage KPIs, set targets, units, and perspectives.</p>
            </div>
            <a asp-controller="Home" asp-action="KpiCreate" class="btn btn-primary-custom d-inline-flex align-items-center gap-2">
                <i class="bi bi-plus-lg"></i> New KPI
            </a>
        </div>

        @if (!kpis.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-bullseye fs-1 d-block mb-3 opacity-25"></i>
                <h6 class="fw-semibold">No KPIs defined yet</h6>
                <p class="mb-3 small">Create your first KPI to start tracking performance.</p>
                <a asp-controller="Home" asp-action="KpiCreate" class="btn btn-primary-custom btn-sm">
                    <i class="bi bi-plus-lg me-1"></i> Create First KPI
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>KPI Name</th>
                            <th>Department</th>
                            <th>Perspective</th>
                            <th>Target</th>
                            <th>Unit</th>
                            <th>Log Entries</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kpi in kpis)
                        {
                            <tr class="@(kpi.IsActive ? "" : "table-secondary text-muted")">
                                <td class="fw-semibold">@kpi.Name</td>
                                <td>@kpi.Department</td>
                                <td><span class="badge bg-light text-dark border">@kpi.Perspective</span></td>
                                <td class="fw-bold text-primary">@kpi.Target</td>
                                <td>@kpi.Unit</td>
                                <td>
                                    <span class="badge @(kpi.LogCount > 0 ? "bg-success" : "bg-secondary") bg-opacity-10 text-@(kpi.LogCount > 0 ? "success" : "secondary") border">
                                        @kpi.LogCount
                                    </span>
                                </td>
                                <td>
                                    @if (kpi.IsActive)
                                    {
                                        <span class="status-badge status-ontrack">Active</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge bg-light text-secondary border">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-controller="Home" asp-action="KpiEdit" asp-route-id="@kpi.Id"
                                           class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-controller="Home" asp-action="KpiToggleActive" asp-route-id="@kpi.Id"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm @(kpi.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    title="@(kpi.IsActive ? "Deactivate" : "Activate")">
                                                <i class="bi @(kpi.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
