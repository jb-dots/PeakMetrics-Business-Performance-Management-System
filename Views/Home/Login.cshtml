@model PeakMetrics.Web.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PeakMetrics</title>
    <link rel="icon" type="image/png" href="~/images/peakmetrics-logo.png" />
    <link rel="shortcut icon" href="~/images/peakmetrics-logo.png" />
    
    <!-- Prevent FOUC (Flash of Unstyled Content) -->
    <script>
        (function() {
            const theme = localStorage.getItem('peakmetrics-theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; }

        /* ─────────────────────────────────────────────
           ANIMATIONS
        ───────────────────────────────────────────── */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-50px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(50px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes scaleIn {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .animate-fade-in-up {
            animation: fadeInUp 0.8s ease-out forwards;
        }

        .animate-slide-in-left {
            animation: slideInLeft 0.8s ease-out forwards;
        }

        .animate-slide-in-right {
            animation: slideInRight 0.8s ease-out forwards;
        }

        .animate-scale-in {
            animation: scaleIn 0.6s ease-out forwards;
        }

        .delay-100 { animation-delay: 0.1s; }
        .delay-200 { animation-delay: 0.2s; }
        .delay-300 { animation-delay: 0.3s; }
        .delay-400 { animation-delay: 0.4s; }
        .delay-500 { animation-delay: 0.5s; }

        body {
            font-family: "Manrope", "Segoe UI", Tahoma, sans-serif;
            background: linear-gradient(135deg, var(--bg-gradient-start) 0%, var(--bg-gradient-mid) 50%, var(--bg-gradient-end) 100%);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            min-height: 100vh;
            position: relative;
            overflow: hidden;
            z-index: 0;
        }

        @@keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Animated floating shapes */
        .bg-shape {
            position: fixed;
            border-radius: 50%;
            opacity: 0.15;
            filter: blur(60px);
            animation: float-shape 20s ease-in-out infinite;
            z-index: -1;
        }

        .bg-shape-1 {
            width: 400px;
            height: 400px;
            background: linear-gradient(135deg, #1e40af, #3b82f6);
            top: -100px;
            left: -100px;
            animation-delay: 0s;
        }

        .bg-shape-2 {
            width: 350px;
            height: 350px;
            background: linear-gradient(135deg, #60a5fa, #93c5fd);
            bottom: -80px;
            right: -80px;
            animation-delay: 5s;
        }

        .bg-shape-3 {
            width: 300px;
            height: 300px;
            background: linear-gradient(135deg, #2563eb, #60a5fa);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation-delay: 10s;
        }

        @@keyframes float-shape {
            0%, 100% {
                transform: translate(0, 0) scale(1);
            }
            33% {
                transform: translate(30px, -30px) scale(1.1);
            }
            66% {
                transform: translate(-20px, 20px) scale(0.9);
            }
        }

        /* Animated icon particles */
        .particle {
            position: fixed;
            color: rgba(255, 255, 255, 0.15);
            font-size: 32px;
            animation: particle-float 20s linear infinite;
            pointer-events: none;
            z-index: -1;
        }

        @@keyframes particle-float {
            0% {
                transform: translateY(0) translateX(0) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 0.2;
            }
            50% {
                opacity: 0.18;
            }
            80% {
                opacity: 0.15;
            }
            100% {
                transform: translateY(-120vh) translateX(30px) rotate(180deg);
                opacity: 0;
            }
        }

        .pm-card {
            width: min(1080px, 100%);
            height: 620px;
            display: flex;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 30px 80px var(--card-shadow), 0 0 0 1px rgba(255, 255, 255, 0.1);
            background: var(--card-bg);
            animation: scaleIn 0.6s ease-out;
            position: relative;
            z-index: 10;
        }

        /* ── Left panel ── */
        .pm-left {
            width: 55%;
            position: relative;
            overflow: hidden;
            color: #fff;
            padding: 52px 56px;
            background: linear-gradient(145deg, #1e3a8a 0%, #1e40af 55%, #3b82f6 100%);
            display: flex;
            flex-direction: column;
        }

        .pm-left::before {
            content: "";
            position: absolute;
            width: 700px; height: 700px;
            border-radius: 50%;
            left: -160px; bottom: -400px;
            background: rgba(147, 197, 253, 0.18);
            pointer-events: none;
        }

        .pm-left::after {
            content: "";
            position: absolute;
            width: 500px; height: 500px;
            border-radius: 50%;
            right: -200px; top: -200px;
            background: rgba(147, 197, 253, 0.12);
            pointer-events: none;
        }

        .pm-left-content, .pm-left-foot { position: relative; z-index: 1; }

        .pm-kicker {
            margin: 0 0 18px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(219, 234, 254, 0.9);
        }

        .pm-headline {
            margin: 0 0 18px;
            font-size: clamp(2.4rem, 4vw, 3.6rem);
            font-weight: 800;
            line-height: 1.0;
            letter-spacing: -0.02em;
        }

        .pm-copy {
            margin: 0;
            font-size: 1rem;
            line-height: 1.5;
            color: rgba(219, 234, 254, 0.88);
            max-width: 420px;
        }

        .pm-left-foot {
            margin-top: auto;
            font-size: 0.88rem;
            color: rgba(219, 234, 254, 0.7);
        }

        /* ── Right panel ── */
        .pm-right {
            width: 45%;
            background: var(--card-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 56px;
        }

        .pm-right-inner { width: 100%; }

        .pm-logo-wrap {
            text-align: center;
            margin-bottom: 20px;
        }

        .pm-logo-img {
            height: 140px;
            width: auto;
            display: block;
            margin: 0 auto;
            object-fit: contain;
        }

        .pm-form-title {
            margin: 0 0 6px;
            font-size: 1.9rem;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.02em;
        }

        .pm-form-sub {
            margin: 0 0 20px;
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .pm-field { margin-bottom: 18px; }

        .pm-field label {
            display: block;
            margin-bottom: 5px;
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .pm-field input {
            width: 100%;
            border: none;
            border-bottom: 2px solid var(--input-border);
            border-radius: 0;
            background: transparent;
            padding: 9px 2px;
            font-size: 0.95rem;
            color: var(--input-text);
            outline: none;
            transition: border-color 0.2s;
        }

        .pm-field input:focus { border-bottom-color: var(--input-border-focus); }
        .pm-field input::placeholder { color: var(--input-placeholder); }
        .pm-field input.is-invalid { border-bottom-color: var(--status-error); }

        .pm-error {
            margin-top: 4px;
            font-size: 0.8rem;
            color: var(--status-error);
        }

        .pm-alert {
            padding: 10px 14px;
            border-radius: 8px;
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #b91c1c;
            font-size: 0.88rem;
            margin-bottom: 16px;
        }

        .pm-btn {
            width: 100%;
            padding: 13px;
            border-radius: 10px;
            font-size: 0.98rem;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
        }

        .pm-btn-primary {
            background: linear-gradient(120deg, var(--btn-primary-bg) 0%, var(--btn-primary-hover) 100%);
            color: var(--btn-primary-text);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
            margin-top: 6px;
        }

        .pm-btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 24px rgba(37, 99, 235, 0.38);
        }

        /* Shake animation for error */
        @@keyframes pm-shake {
            0%, 100% { transform: translateX(0); }
            20%       { transform: translateX(-6px); }
            40%       { transform: translateX(6px); }
            60%       { transform: translateX(-4px); }
            80%       { transform: translateX(4px); }
        }

        .pm-shake { animation: pm-shake 0.4s ease; }

        .pm-hint {
            margin-top: 16px;
            padding: 12px 14px;
            background: #f0f7ff;
            border-radius: 8px;
            border: 1px solid #bfdbfe;
        }

        .pm-hint p {
            margin: 0 0 4px;
            font-size: 0.78rem;
            color: #1e40af;
            font-weight: 600;
        }

        .pm-hint p:last-child { margin-bottom: 0; }

        .pm-hint span {
            font-weight: 400;
            color: #3b82f6;
        }

        @@media (max-width: 900px) {
            body { padding: 0; }
            .pm-card { flex-direction: column; height: auto; min-height: 100vh; border-radius: 0; box-shadow: none; }
            .pm-left, .pm-right { width: 100%; }
            .pm-left { padding: 36px 28px; min-height: 280px; }
            .pm-right { padding: 28px 24px 36px; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <!-- Animated background shapes -->
    <div class="bg-shape bg-shape-1"></div>
    <div class="bg-shape bg-shape-2"></div>
    <div class="bg-shape bg-shape-3"></div>
    
    <!-- Floating icon particles - rising like bubbles -->
    <i class="particle bi bi-graph-up" style="left: 8%; bottom: 10%; animation-delay: 0s;"></i>
    <i class="particle bi bi-bar-chart-line" style="left: 15%; bottom: 5%; animation-delay: 3s;"></i>
    <i class="particle bi bi-pie-chart" style="left: 12%; bottom: 15%; animation-delay: 6s;"></i>
    <i class="particle bi bi-graph-up-arrow" style="left: 5%; bottom: 8%; animation-delay: 2s;"></i>
    <i class="particle bi bi-bar-chart-fill" style="left: 10%; bottom: 20%; animation-delay: 5s;"></i>
    
    <i class="particle bi bi-graph-down" style="left: 88%; bottom: 12%; animation-delay: 8s;"></i>
    <i class="particle bi bi-bar-chart" style="left: 92%; bottom: 6%; animation-delay: 4s;"></i>
    <i class="particle bi bi-pie-chart-fill" style="left: 95%; bottom: 18%; animation-delay: 7s;"></i>
    <i class="particle bi bi-activity" style="left: 85%; bottom: 10%; animation-delay: 1s;"></i>
    <i class="particle bi bi-graph-up" style="left: 90%; bottom: 14%; animation-delay: 9s;"></i>
    
    <div class="pm-card">
        <section class="pm-left">
            <div class="pm-left-content">
                <p class="pm-kicker animate-fade-in-up">Analytics &amp; Insights Platform</p>
                <h1 class="pm-headline animate-fade-in-up delay-100">Hello,<br>PeakMetrics<br>Team</h1>
                <p class="pm-copy animate-fade-in-up delay-200">Monitor performance, automate reporting, and keep every KPI aligned to strategy.</p>
            </div>
            <p class="pm-left-foot animate-fade-in-up delay-300">PeakMetrics &copy; @DateTime.Now.Year</p>
        </section>

        <section class="pm-right">
            <div class="pm-right-inner">
                <div class="pm-logo-wrap animate-scale-in">
                    <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics" class="pm-logo-img" />
                </div>

                <h2 class="pm-form-title animate-fade-in-up delay-200">Welcome Back</h2>
                <p class="pm-form-sub animate-fade-in-up delay-300">Sign in to continue to your dashboard.</p>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
                {
                    <div class="pm-alert pm-shake" id="loginError">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @{ var modelError = ViewData.ModelState[string.Empty]?.Errors.FirstOrDefault()?.ErrorMessage; }
                        @modelError
                    </div>
                }

                <form asp-controller="Home" asp-action="Login" method="post" id="loginForm" novalidate class="animate-fade-in-up delay-400">
                    @Html.AntiForgeryToken()

                    <div class="pm-field">
                        <label asp-for="Email">Email Address</label>
                        <input asp-for="Email" type="email" placeholder="you@peakmetrics.com"
                               id="loginEmail"
                               class="@(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <div class="pm-error" id="emailError">@Html.ValidationMessageFor(m => m.Email)</div>
                    </div>

                    <div class="pm-field">
                        <label asp-for="Password">Password</label>
                        <div style="position:relative;">
                            <input asp-for="Password" type="password" placeholder="Enter your password"
                                   id="loginPassword"
                                   style="padding-right:2.2rem;"
                                   class="@(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                            <button type="button" onclick="togglePw('loginPassword',this)"
                                    style="position:absolute;right:4px;top:50%;transform:translateY(-50%);background:none;border:none;padding:4px;cursor:pointer;color:#64748b;line-height:1;"
                                    aria-label="Show password">
                                <i class="bi bi-eye" style="font-size:1rem;"></i>
                            </button>
                        </div>
                        <div class="pm-error" id="passwordError">@Html.ValidationMessageFor(m => m.Password)</div>
                    </div>

                    <p class="text-end mt-2" style="font-size:0.88rem;">
                        <a href="/Account/ForgotPassword" style="color:var(--link-color); font-weight:600;">Forgot Password?</a>
                    </p>

                    <button type="submit" class="pm-btn pm-btn-primary" id="loginBtn">Sign In</button>
                </form>

                <p class="text-center mt-3 animate-fade-in-up delay-500" style="font-size:0.88rem; color:var(--text-secondary);">
                    Don't have an account?
                    <a href="/Account/Register" style="color:var(--link-color); font-weight:600;">Register here</a>
                </p>

                <script>
                function togglePw(id, btn) {
                    var input = document.getElementById(id);
                    var icon = btn.querySelector('i');
                    if (input.type === 'password') {
                        input.type = 'text';
                        icon.className = 'bi bi-eye-slash';
                        btn.setAttribute('aria-label', 'Hide password');
                    } else {
                        input.type = 'password';
                        icon.className = 'bi bi-eye';
                        btn.setAttribute('aria-label', 'Show password');
                    }
                }
                (function () {
                    var form     = document.getElementById('loginForm');
                    var email    = document.getElementById('loginEmail');
                    var password = document.getElementById('loginPassword');
                    var emailErr = document.getElementById('emailError');
                    var passErr  = document.getElementById('passwordError');
                    var btn      = document.getElementById('loginBtn');

                    function validateEmail(val) {
                        if (!val) return 'Email is required.';
                        var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                        if (!re.test(val)) return 'Enter a valid email address.';
                        return '';
                    }

                    function validatePassword(val) {
                        if (!val) return 'Password is required.';
                        return '';
                    }

                    function setError(input, errEl, msg) {
                        errEl.textContent = msg;
                        if (msg) {
                            input.classList.add('is-invalid');
                        } else {
                            input.classList.remove('is-invalid');
                        }
                    }

                    email.addEventListener('input', function () {
                        setError(email, emailErr, validateEmail(email.value.trim()));
                    });

                    password.addEventListener('input', function () {
                        setError(password, passErr, validatePassword(password.value));
                    });

                    form.addEventListener('submit', function (e) {
                        var eErr = validateEmail(email.value.trim());
                        var pErr = validatePassword(password.value);
                        setError(email, emailErr, eErr);
                        setError(password, passErr, pErr);
                        if (eErr || pErr) {
                            e.preventDefault();
                            form.classList.add('pm-shake');
                            setTimeout(function () { form.classList.remove('pm-shake'); }, 500);
                        } else {
                            btn.disabled = true;
                            btn.textContent = 'Signing in...';
                        }
                    });
                })();
                </script>
            </div>
        </section>
    </div>
</body>
</html>
