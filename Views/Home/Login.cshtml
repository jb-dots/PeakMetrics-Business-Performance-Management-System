@model PeakMetrics.Web.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PeakMetrics</title>
    <link rel="icon" type="image/png" href="~/images/peakmetrics-logo.png" />
    <link rel="shortcut icon" href="~/images/peakmetrics-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; }

        body {
            font-family: "Manrope", "Segoe UI", Tahoma, sans-serif;
            background: #eef2f9;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            min-height: 100vh;
        }

        .pm-card {
            width: min(1080px, 100%);
            height: 620px;
            display: flex;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 20px 48px rgba(16, 24, 40, 0.16);
            background: #fff;
        }

        /* ── Left panel ── */
        .pm-left {
            width: 55%;
            position: relative;
            overflow: hidden;
            color: #fff;
            padding: 52px 56px;
            background: linear-gradient(145deg, #2563eb 0%, #1d4ed8 55%, #1e40af 100%);
            display: flex;
            flex-direction: column;
        }

        .pm-left::before {
            content: "";
            position: absolute;
            width: 700px; height: 700px;
            border-radius: 50%;
            left: -160px; bottom: -400px;
            background: rgba(147, 197, 253, 0.18);
            pointer-events: none;
        }

        .pm-left::after {
            content: "";
            position: absolute;
            width: 500px; height: 500px;
            border-radius: 50%;
            right: -200px; top: -200px;
            background: rgba(147, 197, 253, 0.12);
            pointer-events: none;
        }

        .pm-left-content, .pm-left-foot { position: relative; z-index: 1; }

        .pm-kicker {
            margin: 0 0 18px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(219, 234, 254, 0.9);
        }

        .pm-headline {
            margin: 0 0 18px;
            font-size: clamp(2.4rem, 4vw, 3.6rem);
            font-weight: 800;
            line-height: 1.0;
            letter-spacing: -0.02em;
        }

        .pm-copy {
            margin: 0;
            font-size: 1rem;
            line-height: 1.5;
            color: rgba(219, 234, 254, 0.88);
            max-width: 420px;
        }

        .pm-left-foot {
            margin-top: auto;
            font-size: 0.88rem;
            color: rgba(219, 234, 254, 0.7);
        }

        /* ── Right panel ── */
        .pm-right {
            width: 45%;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 56px;
        }

        .pm-right-inner { width: 100%; }

        .pm-logo-wrap {
            text-align: center;
            margin-bottom: 20px;
        }

        .pm-logo-img {
            height: 140px;
            width: auto;
            display: block;
            margin: 0 auto;
            object-fit: contain;
        }

        .pm-form-title {
            margin: 0 0 6px;
            font-size: 1.9rem;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.02em;
        }

        .pm-form-sub {
            margin: 0 0 20px;
            font-size: 0.9rem;
            color: #64748b;
        }

        .pm-field { margin-bottom: 18px; }

        .pm-field label {
            display: block;
            margin-bottom: 5px;
            font-size: 0.88rem;
            font-weight: 600;
            color: #1e293b;
        }

        .pm-field input {
            width: 100%;
            border: none;
            border-bottom: 2px solid #cbd5e1;
            border-radius: 0;
            background: transparent;
            padding: 9px 2px;
            font-size: 0.95rem;
            color: #0f172a;
            outline: none;
            transition: border-color 0.2s;
        }

        .pm-field input:focus { border-bottom-color: #2563eb; }
        .pm-field input::placeholder { color: #94a3b8; }
        .pm-field input.is-invalid { border-bottom-color: #ef4444; }

        .pm-error {
            margin-top: 4px;
            font-size: 0.8rem;
            color: #ef4444;
        }

        .pm-alert {
            padding: 10px 14px;
            border-radius: 8px;
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #b91c1c;
            font-size: 0.88rem;
            margin-bottom: 16px;
        }

        .pm-btn {
            width: 100%;
            padding: 13px;
            border-radius: 10px;
            font-size: 0.98rem;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
        }

        .pm-btn-primary {
            background: linear-gradient(120deg, #2563eb 0%, #1d4ed8 100%);
            color: #fff;
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
            margin-top: 6px;
        }

        .pm-btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 24px rgba(37, 99, 235, 0.38);
        }

        /* Shake animation for error */
        @@keyframes pm-shake {
            0%, 100% { transform: translateX(0); }
            20%       { transform: translateX(-6px); }
            40%       { transform: translateX(6px); }
            60%       { transform: translateX(-4px); }
            80%       { transform: translateX(4px); }
        }

        .pm-shake { animation: pm-shake 0.4s ease; }

        .pm-hint {
            margin-top: 16px;
            padding: 12px 14px;
            background: #f0f7ff;
            border-radius: 8px;
            border: 1px solid #bfdbfe;
        }

        .pm-hint p {
            margin: 0 0 4px;
            font-size: 0.78rem;
            color: #1e40af;
            font-weight: 600;
        }

        .pm-hint p:last-child { margin-bottom: 0; }

        .pm-hint span {
            font-weight: 400;
            color: #3b82f6;
        }

        @@media (max-width: 900px) {
            body { padding: 0; }
            .pm-card { flex-direction: column; height: auto; min-height: 100vh; border-radius: 0; box-shadow: none; }
            .pm-left, .pm-right { width: 100%; }
            .pm-left { padding: 36px 28px; min-height: 280px; }
            .pm-right { padding: 28px 24px 36px; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <div class="pm-card">
        <section class="pm-left">
            <div class="pm-left-content">
                <p class="pm-kicker">Analytics &amp; Insights Platform</p>
                <h1 class="pm-headline">Hello,<br>PeakMetrics<br>Team</h1>
                <p class="pm-copy">Monitor performance, automate reporting, and keep every KPI aligned to strategy.</p>
            </div>
            <p class="pm-left-foot">PeakMetrics &copy; @DateTime.Now.Year</p>
        </section>

        <section class="pm-right">
            <div class="pm-right-inner">
                <div class="pm-logo-wrap">
                    <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics" class="pm-logo-img" />
                </div>

                <h2 class="pm-form-title">Welcome Back</h2>
                <p class="pm-form-sub">Sign in to continue to your dashboard.</p>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
                {
                    <div class="pm-alert pm-shake" id="loginError">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @Html.ValidationMessage(string.Empty)
                    </div>
                }

                <form asp-controller="Home" asp-action="Login" method="post" id="loginForm" novalidate>
                    @Html.AntiForgeryToken()

                    <div class="pm-field">
                        <label asp-for="Email">Email Address</label>
                        <input asp-for="Email" type="email" placeholder="you@peakmetrics.com"
                               id="loginEmail"
                               class="@(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <div class="pm-error" id="emailError">@Html.ValidationMessageFor(m => m.Email)</div>
                    </div>

                    <div class="pm-field">
                        <label asp-for="Password">Password</label>
                        <input asp-for="Password" type="password" placeholder="Enter your password"
                               id="loginPassword"
                               class="@(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <div class="pm-error" id="passwordError">@Html.ValidationMessageFor(m => m.Password)</div>
                    </div>

                    <button type="submit" class="pm-btn pm-btn-primary" id="loginBtn">Sign In</button>
                </form>

                <script>
                (function () {
                    var form     = document.getElementById('loginForm');
                    var email    = document.getElementById('loginEmail');
                    var password = document.getElementById('loginPassword');
                    var emailErr = document.getElementById('emailError');
                    var passErr  = document.getElementById('passwordError');
                    var btn      = document.getElementById('loginBtn');

                    function validateEmail(val) {
                        if (!val) return 'Email is required.';
                        var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                        if (!re.test(val)) return 'Enter a valid email address.';
                        return '';
                    }

                    function validatePassword(val) {
                        if (!val) return 'Password is required.';
                        return '';
                    }

                    function setError(input, errEl, msg) {
                        errEl.textContent = msg;
                        if (msg) {
                            input.classList.add('is-invalid');
                        } else {
                            input.classList.remove('is-invalid');
                        }
                    }

                    email.addEventListener('input', function () {
                        setError(email, emailErr, validateEmail(email.value.trim()));
                    });

                    password.addEventListener('input', function () {
                        setError(password, passErr, validatePassword(password.value));
                    });

                    form.addEventListener('submit', function (e) {
                        var eErr = validateEmail(email.value.trim());
                        var pErr = validatePassword(password.value);
                        setError(email, emailErr, eErr);
                        setError(password, passErr, pErr);
                        if (eErr || pErr) {
                            e.preventDefault();
                            form.classList.add('pm-shake');
                            setTimeout(function () { form.classList.remove('pm-shake'); }, 500);
                        } else {
                            btn.disabled = true;
                            btn.textContent = 'Signing in...';
                        }
                    });
                })();
                </script>
            </div>
        </section>
    </div>
</body>
</html>
