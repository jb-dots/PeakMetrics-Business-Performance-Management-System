@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PeakMetrics</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" />
    <link rel="icon" type="image/png" href="~/images/peakmetrics-logo.png" />
    <link rel="shortcut icon" href="~/images/peakmetrics-logo.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-body">
    @{ var logoFallbackScript = "this.classList.add('d-none'); var fallback = this.parentElement.querySelector('.login-logo-fallback'); if (fallback) { fallback.classList.remove('d-none'); }"; }
    <div class="login-page">
        <div class="login-shell">
            <section class="login-showcase" aria-label="PeakMetrics introduction">
                <div class="login-showcase-content">
                    <h1 class="brand-title d-none">PeakMetrics</h1>
                    <p class="login-showcase-kicker">Analytics and Insights Platform</p>
                    <h2 class="login-showcase-title">Hello, PeakMetrics Team</h2>
                    <p class="login-showcase-copy">Monitor performance, automate reporting, and keep every KPI aligned to strategy.</p>
                </div>
                <p class="login-showcase-foot">PeakMetrics Analytics and Insights</p>
            </section>

            <section class="login-panel" aria-label="Login form">
                <div class="login-panel-inner">
                    <div class="login-panel-logo-wrap">
                        <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics logo" class="login-panel-logo" onerror="@logoFallbackScript" />
                        <span class="login-logo-fallback d-none">PeakMetrics</span>
                    </div>
                    <h2 class="login-panel-title">Welcome Back!</h2>
                    <p class="login-panel-subtitle">Sign in to continue to your performance dashboard.</p>

                    <form asp-controller="Home" asp-action="Dashboard" method="get">
                        <div class="login-form-group">
                            <label for="email" class="form-label fw-semibold login-panel-label">Email Address</label>
                            <input type="email" class="form-control login-form-input" id="email" placeholder="Enter your email" required />
                        </div>
                        <div class="login-form-group">
                            <label for="password" class="form-label fw-semibold login-panel-label">Password</label>
                            <input type="password" class="form-control login-form-input" id="password" placeholder="Enter your password" required />
                        </div>
                        <button type="submit" class="btn btn-primary-custom login-primary-btn">Login Now</button>
                        <button type="button" class="btn login-secondary-btn">
                            <span class="login-google-mark" aria-hidden="true">
                                <svg viewBox="0 0 24 24" width="18" height="18" role="img" aria-label="Google logo">
                                    <path fill="#4285F4" d="M23.49 12.27c0-.79-.07-1.55-.2-2.27H12v4.3h6.45a5.52 5.52 0 0 1-2.4 3.62v3h3.88c2.27-2.09 3.56-5.17 3.56-8.65z" />
                                    <path fill="#34A853" d="M12 24c3.24 0 5.95-1.07 7.93-2.91l-3.88-3c-1.08.72-2.46 1.14-4.05 1.14-3.11 0-5.75-2.1-6.69-4.93H1.3v3.09A12 12 0 0 0 12 24z" />
                                    <path fill="#FBBC05" d="M5.31 14.3A7.2 7.2 0 0 1 4.94 12c0-.8.14-1.57.37-2.3V6.61H1.3A12 12 0 0 0 0 12c0 1.94.46 3.77 1.3 5.39l4.01-3.09z" />
                                    <path fill="#EA4335" d="M12 4.77c1.76 0 3.34.61 4.58 1.8l3.44-3.44C17.94 1.2 15.24 0 12 0A12 12 0 0 0 1.3 6.61l4.01 3.09C6.25 6.87 8.89 4.77 12 4.77z" />
                                </svg>
                            </span>
                            Continue with Google
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a href="#" class="login-forgot-link">Forgot password?</a>
                    </div>
                </div>
            </section>
        </div>
    </div>
</body>
</html>
