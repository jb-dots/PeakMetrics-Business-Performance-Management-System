@model IEnumerable<PeakMetrics.Web.ViewModels.PendingUserViewModel>
@{
    ViewData["Title"] = "Pending Approvals";
}

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="page-title mb-1">Pending Approvals</h2>
        <p class="text-muted mb-0">Users who have verified their email and are awaiting account approval.</p>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card-clean p-5 text-center">
        <i class="bi bi-person-check" style="font-size:3rem;color:#94a3b8;"></i>
        <h5 class="mt-3 mb-1" style="color:#475569;">No pending approvals</h5>
        <p class="text-muted mb-0">All registered users have been reviewed.</p>
    </div>
}
else
{
    <div class="card-clean">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Requested Role</th>
                        <th>Department</th>
                        <th>Registration Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="sidebar-user-avatar" style="width:36px;height:36px;font-size:0.8rem;flex-shrink:0;">
                                        @(string.Concat(user.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(p => p[0].ToString().ToUpper())))
                                    </div>
                                    <span class="fw-semibold">@user.FullName</span>
                                </div>
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                <span class="badge @(user.RequestedRole == "Manager" ? "bg-primary" : "bg-secondary") bg-opacity-10 text-@(user.RequestedRole == "Manager" ? "primary" : "secondary") fw-semibold px-2 py-1">
                                    @(user.RequestedRole ?? "Staff")
                                </span>
                            </td>
                            <td class="text-muted">@(user.DepartmentName ?? "—")</td>
                            <td class="text-muted">@user.RegistrationDate.ToString("MMM d, yyyy")</td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <form asp-action="ApproveUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success"
                                                onclick="return confirm('Approve @Html.Raw(user.FullName.Replace("'", "\\'"))\'s account?')">
                                            <i class="bi bi-check-lg me-1"></i>Approve
                                        </button>
                                    </form>
                                    <form asp-action="RejectUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger"
                                                onclick="return confirm('Reject and delete @Html.Raw(user.FullName.Replace("'", "\\'"))\'s account? This cannot be undone.')">
                                            <i class="bi bi-x-lg me-1"></i>Reject
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
