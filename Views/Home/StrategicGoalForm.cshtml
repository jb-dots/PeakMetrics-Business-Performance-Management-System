@model PeakMetrics.Web.ViewModels.StrategicGoalFormViewModel
@{
    var isEdit = Model.Id > 0;
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-7">
        <div class="card card-clean">
            <div class="card-body p-4">
                <h5 class="card-title mb-1">@(isEdit ? "Edit Strategic Goal" : "Add Strategic Goal")</h5>
                <p class="text-muted small mb-4">
                    @(isEdit
                        ? "Update the goal details. Status changes are tracked in the audit log."
                        : "Define a new strategic goal. Link it to a BSC perspective and set a target completion date.")
                </p>

                <form asp-controller="Home"
                      asp-action="@(isEdit ? "StrategicGoalEdit" : "StrategicGoalCreate")"
                      method="post">
                    @Html.AntiForgeryToken()
                    @if (isEdit)
                    {
                        <input type="hidden" asp-for="Id" />
                    }

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold">Goal Title</label>
                        <input asp-for="Title" class="form-control @(ViewData.ModelState["Title"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="e.g., Digital Transformation Initiative" autofocus />
                        <div class="invalid-feedback">@Html.ValidationMessageFor(m => m.Title)</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">
                            Description <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Describe what this goal aims to achieve..."></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="PerspectiveId" class="form-label fw-semibold">BSC Perspective</label>
                            <select asp-for="PerspectiveId" class="form-select @(ViewData.ModelState["PerspectiveId"]?.Errors.Count > 0 ? "is-invalid" : "")">
                                <option value="">— Select Perspective —</option>
                                @foreach (var p in Model.Perspectives)
                                {
                                    var sel = Model.PerspectiveId == p.Id;
                                    <option value="@p.Id" selected="@(sel ? "selected" : null)">@p.Name</option>
                                }
                            </select>
                            <div class="invalid-feedback">@Html.ValidationMessageFor(m => m.PerspectiveId)</div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold">Status</label>
                            <select asp-for="Status" class="form-select">
                                @foreach (var s in new[] { "Not Started", "In Progress", "Completed", "Cancelled" })
                                {
                                    var sel = Model.Status == s || (string.IsNullOrEmpty(Model.Status) && s == "Not Started");
                                    <option value="@s" selected="@(sel ? "selected" : null)">@s</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="TargetYear" class="form-label fw-semibold">
                            Target Year <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <input asp-for="TargetYear" type="number" min="2000" max="2100" class="form-control"
                               placeholder="e.g., 2026" />
                        <div class="invalid-feedback">@Html.ValidationMessageFor(m => m.TargetYear)</div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-controller="Home" asp-action="StrategicPlanning"
                           class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary-custom d-inline-flex align-items-center gap-2">
                            <i class="bi bi-floppy"></i>
                            @(isEdit ? "Save Changes" : "Add Goal")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
