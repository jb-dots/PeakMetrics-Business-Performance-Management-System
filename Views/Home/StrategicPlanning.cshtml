@model PeakMetrics.Web.ViewModels.StrategicPlanningViewModel
@{
    var role       = ViewData["SessionUserRole"]?.ToString() ?? string.Empty;
    var canManage  = role is "Admin" or "Manager";
}

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-check-circle-fill"></i>
        <span>@Html.Raw(successMsg)</span>
    </div>
}

@if (canManage)
{
    <div class="d-flex justify-content-end mb-4">
        <a asp-controller="Home" asp-action="StrategicGoalCreate"
           class="btn btn-primary-custom d-inline-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i> Add Strategic Goal
        </a>
    </div>
}

@if (!Model.Goals.Any())
{
    <div class="card card-clean">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-lightbulb fs-1 d-block mb-3 opacity-25"></i>
            <h5 class="fw-semibold">No strategic goals yet</h5>
            <p class="mb-3 small">Define strategic goals to track your organisation's long-term direction.</p>
            @if (canManage)
            {
                <a asp-controller="Home" asp-action="StrategicGoalCreate" class="btn btn-primary-custom btn-sm">
                    <i class="bi bi-plus-lg me-1"></i> Add First Goal
                </a>
            }
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var goal in Model.Goals)
        {
            var statusCss = goal.Status switch
            {
                "In Progress"  => "status-badge status-ontrack",
                "Completed"    => "status-badge status-ontrack",
                "Not Started"  => "status-badge bg-light text-secondary border",
                "Cancelled"    => "status-badge bg-light text-secondary border",
                _              => "status-badge bg-light text-secondary border"
            };

            var perspectiveColor = goal.Perspective switch
            {
                "Financial"         => "#1B4FD8",
                "Customer"          => "#0891b2",
                "Internal Process"  => "#7c3aed",
                "Learning & Growth" => "#059669",
                _                   => "#64748b"
            };

            <div class="col-12 col-lg-6">
                <div class="card card-clean h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                            <div class="min-width-0 flex-grow-1">
                                <h5 class="mb-2 fw-semibold">@goal.Title</h5>
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <span class="badge rounded-pill"
                                          style="background:@(perspectiveColor)22;color:@perspectiveColor;font-size:0.75rem;">
                                        @goal.Perspective
                                    </span>
                                    <span class="@statusCss">@goal.Status</span>
                                </div>
                            </div>
                            @if (canManage)
                            {
                                <a asp-controller="Home" asp-action="StrategicGoalEdit" asp-route-id="@goal.Id"
                                   class="btn btn-sm btn-outline-secondary flex-shrink-0" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(goal.Description))
                        {
                            <p class="text-muted mb-3" style="font-size:0.88rem;">@goal.Description</p>
                        }

                        <div class="d-flex flex-wrap gap-3 small text-muted">
                            @if (!string.IsNullOrWhiteSpace(goal.DueDate))
                            {
                                <span><i class="bi bi-calendar3 me-1"></i>Due: @goal.DueDate</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(goal.OwnerName))
                            {
                                <span><i class="bi bi-person me-1"></i>@goal.OwnerName</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
