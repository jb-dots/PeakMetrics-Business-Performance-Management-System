@model PeakMetrics.Web.ViewModels.StrategicPlanningViewModel
@{
    var role        = ViewData["SessionUserRole"]?.ToString() ?? string.Empty;
    var canManage   = role is "Admin" or "Manager";
    var showArchived = (bool)(ViewBag.ShowArchived ?? false);

    // Perspective config — same as Balanced Scorecards
    var perspectiveConfig = new Dictionary<string, (string Color, string Icon)>
    {
        ["Financial"]         = ("#1B4FD8", "bi-currency-exchange"),
        ["Customer"]          = ("#0891b2", "bi-people"),
        ["Internal Process"]  = ("#7c3aed", "bi-gear"),
        ["Learning & Growth"] = ("#059669", "bi-mortarboard"),
    };

    // Status priority config
    static (string Css, string Icon, int Priority) StatusConfig(string status) => status switch
    {
        "In Progress" => ("goal-status-inprogress", "bi-play-circle-fill", 1),
        "Not Started" => ("goal-status-notstarted", "bi-circle",           2),
        "Completed"   => ("goal-status-completed",  "bi-check-circle-fill",3),
        "Cancelled"   => ("goal-status-cancelled",  "bi-x-circle-fill",   4),
        _             => ("goal-status-notstarted",  "bi-circle",          5)
    };

    var goals = Model.Goals.OrderBy(g => StatusConfig(g.Status).Priority).ToList();
}

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-check-circle-fill"></i>
        <span>@Html.Raw(successMsg)</span>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div class="d-flex gap-2">
        <a asp-controller="Home" asp-action="StrategicPlanning" asp-route-showArchived="false"
           class="btn btn-sm @(!showArchived ? "btn-primary-custom" : "btn-outline-secondary")">
            <i class="bi bi-lightbulb me-1"></i> Active
        </a>
        <a asp-controller="Home" asp-action="StrategicPlanning" asp-route-showArchived="true"
           class="btn btn-sm @(showArchived ? "btn-primary-custom" : "btn-outline-secondary")">
            <i class="bi bi-archive me-1"></i> Archived
        </a>
    </div>
    @if (canManage && !showArchived)
    {
        <a asp-controller="Home" asp-action="StrategicGoalCreate"
           class="btn btn-primary-custom d-inline-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i> Add Strategic Goal
        </a>
    }
</div>

@if (!goals.Any())
{
    <div class="card card-clean">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi @(showArchived ? "bi-archive" : "bi-lightbulb") fs-1 d-block mb-3 opacity-25"></i>
            <h5 class="fw-semibold">@(showArchived ? "No archived goals" : "No strategic goals yet")</h5>
            <p class="mb-3 small">
                @(showArchived
                    ? "Archived goals will appear here."
                    : "Define strategic goals to track your organisation's long-term direction.")
            </p>
            @if (canManage && !showArchived)
            {
                <a asp-controller="Home" asp-action="StrategicGoalCreate" class="btn btn-primary-custom btn-sm">
                    <i class="bi bi-plus-lg me-1"></i> Add First Goal
                </a>
            }
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var goal in goals)
        {
            var (statusCss, statusIcon, _) = StatusConfig(goal.Status);
            var (perspColor, perspIcon) = perspectiveConfig.TryGetValue(goal.Perspective, out var pc)
                ? pc : ("#64748b", "bi-flag");

            <div class="col-12 col-lg-6">
                <div class="card goal-card h-100 overflow-hidden @(goal.IsArchived ? "goal-card-archived" : "")">
                    @* Colored perspective header — same style as Balanced Scorecards *@
                    <div class="goal-card-header text-white d-flex align-items-center justify-content-between"
                         style="background:@perspColor;">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi @perspIcon"></i>
                            <span class="fw-semibold">@goal.Perspective</span>
                        </div>
                        <span class="goal-status-pill @statusCss">
                            <i class="bi @statusIcon me-1"></i>@goal.Status
                        </span>
                    </div>

                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <h5 class="mb-0 fw-semibold goal-title">@goal.Title</h5>
                            @if (canManage && !showArchived)
                            {
                                <div class="d-flex gap-1 flex-shrink-0">
                                    <a asp-controller="Home" asp-action="StrategicGoalEdit" asp-route-id="@goal.Id"
                                       class="btn btn-sm btn-outline-secondary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-controller="Home" asp-action="StrategicGoalArchive" asp-route-id="@goal.Id"
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="Archive">
                                            <i class="bi bi-archive"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                            @if (canManage && showArchived)
                            {
                                <form asp-controller="Home" asp-action="StrategicGoalArchive" asp-route-id="@goal.Id"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-success flex-shrink-0" title="Restore">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i>Restore
                                    </button>
                                </form>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(goal.Description))
                        {
                            <p class="text-muted mb-3" style="font-size:0.88rem;">@goal.Description</p>
                        }

                        <div class="d-flex flex-wrap gap-3 small text-muted mt-auto">
                            @if (!string.IsNullOrWhiteSpace(goal.DueDate))
                            {
                                <span><i class="bi bi-calendar3 me-1"></i>Due: @goal.DueDate</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(goal.OwnerName))
                            {
                                <span><i class="bi bi-person me-1"></i>@goal.OwnerName</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
