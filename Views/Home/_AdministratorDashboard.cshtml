@model PeakMetrics.Web.ViewModels.AdministratorDashboardViewModel
@using System.Text.Json

@{
    var cards = new List<(string Title, string Value, string Icon)>
    {
        ("Total Users",          Model.TotalUsers.ToString(),        "bi-people"),
        ("Total Departments",    Model.TotalDepartments.ToString(),  "bi-building"),
        ("Total KPIs",           Model.TotalKpis.ToString(),         "bi-bullseye"),
        ("Active Roles",         Model.ActiveRoles.ToString(),       "bi-person-badge"),
        ("Pending KPIs",         Model.PendingKpis.ToString(),       "bi-hourglass-split"),
        ("New Users This Month", Model.NewUsersThisMonth.ToString(), "bi-person-plus"),
    };
}

@await Html.PartialAsync("_SummaryCards", null, new ViewDataDictionary(ViewData) { ["Cards"] = cards })

<!-- Unread Notifications -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card card-clean">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-3"
                     style="width:48px;height:48px;background:#EFF6FF;">
                    <i class="bi bi-bell" style="font-size:1.3rem;color:#1B4FD8;"></i>
                </div>
                <div>
                    <p class="text-muted mb-0 small">Unread Notifications</p>
                    <h4 class="mb-0 fw-bold">
                        @Model.UnreadNotifications
                        @if (Model.UnreadNotifications > 0)
                        {
                            <span class="badge rounded-pill ms-2" style="background:#ef4444;font-size:0.75rem;">@Model.UnreadNotifications unread</span>
                        }
                    </h4>
                </div>
                <div class="ms-auto">
                    <a asp-controller="Home" asp-action="Notifications" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- KPI Status Overview + Role Distribution Chart -->
<div class="row g-4 mb-4">
    <!-- KPI Status Overview -->
    <div class="col-12 col-lg-6">
        <div class="card card-clean h-100">
            <div class="card-body">
                <h5 class="card-title mb-3">KPI Status Overview</h5>
                <p class="text-muted small mb-3">Read-only counts based on the latest log entry per KPI.</p>
                <div class="row g-3">
                    <div class="col-4">
                        <div class="rounded-3 p-3 text-center" style="background:#f0fdf4;">
                            <div class="fw-bold fs-2" style="color:#16a34a;">@Model.KpiOnTrack</div>
                            <div class="small fw-semibold mt-1" style="color:#15803d;">
                                <i class="bi bi-check-circle-fill me-1"></i>On Track
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="rounded-3 p-3 text-center" style="background:#fefce8;">
                            <div class="fw-bold fs-2" style="color:#ca8a04;">@Model.KpiAtRisk</div>
                            <div class="small fw-semibold mt-1" style="color:#a16207;">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>At Risk
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="rounded-3 p-3 text-center" style="background:#fef2f2;">
                            <div class="fw-bold fs-2" style="color:#dc2626;">@Model.KpiBehind</div>
                            <div class="small fw-semibold mt-1" style="color:#b91c1c;">
                                <i class="bi bi-x-circle-fill me-1"></i>Behind
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- User Role Distribution Chart -->
    <div class="col-12 col-lg-6">
        <div class="card card-clean h-100">
            <div class="card-body">
                <h5 class="card-title mb-3">User Role Distribution</h5>
                @if (Model.RoleDistribution.Count == 0)
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-pie-chart fs-1 d-block mb-2 opacity-25"></i>
                        <p class="mb-0 small">No role data available.</p>
                    </div>
                }
                else
                {
                    <canvas id="adminRoleChart"
                            data-labels="@JsonSerializer.Serialize(Model.RoleDistribution.Keys.ToList())"
                            data-datasets="@JsonSerializer.Serialize(Model.RoleDistribution.Values.ToList())"
                            style="max-height:220px;"></canvas>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Recent Users (top 5) -->
    <div class="col-12 col-lg-8">
        <div class="card card-clean">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Recent Users</h5>
                    <a asp-controller="Home" asp-action="UserManagement"
                       class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                @if (!Model.RecentUsers.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-people fs-1 d-block mb-2 opacity-25"></i>
                        <p class="mb-0 small">No users found.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Full Name</th>
                                    <th>Role</th>
                                    <th>Department</th>
                                    <th>Joined</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.RecentUsers)
                                {
                                    <tr>
                                        <td class="fw-semibold">@user.FullName</td>
                                        <td>
                                            <span class="status-badge status-ontrack">@user.Role</span>
                                        </td>
                                        <td class="text-muted">@user.DepartmentName</td>
                                        <td class="text-muted small">@user.CreatedAt</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Department Summary -->
    <div class="col-12 col-lg-4">
        <div class="card card-clean">
            <div class="card-body">
                <h5 class="card-title mb-3">Department Summary</h5>
                @if (!Model.Departments.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-building fs-1 d-block mb-2 opacity-25"></i>
                        <p class="mb-0 small">No departments found.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Users</th>
                                    <th>KPIs</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dept in Model.Departments)
                                {
                                    <tr>
                                        <td class="fw-semibold">@dept.Name</td>
                                        <td>@dept.UserCount</td>
                                        <td>@dept.ActiveKpiCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- System Logs: recent user movements (non-admin only) -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card card-clean">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h5 class="card-title mb-0">System Logs</h5>
                        <p class="text-muted small mb-0 mt-1">Recent activity from Administrators, Managers, Staff, and Executives.</p>
                    </div>
                </div>
                @if (!Model.RecentSystemLogs.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-activity fs-1 d-block mb-2 opacity-25"></i>
                        <p class="mb-0 small">No user activity recorded yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Entity Type</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.RecentSystemLogs)
                                {
                                    var nameParts = log.UserName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                    var initials  = nameParts.Length >= 2
                                        ? $"{nameParts[0][0]}{nameParts[^1][0]}"
                                        : log.UserName[..Math.Min(2, log.UserName.Length)];

                                    var actionCss = log.Action.Contains("Login")   ? "status-badge status-ontrack"
                                                  : log.Action.Contains("Logout")  ? "status-badge bg-light text-secondary border"
                                                  : log.Action.Contains("Created") ? "status-badge status-ontrack"
                                                  : log.Action.Contains("Deleted") ? "status-badge status-behind"
                                                  : "status-badge status-atrisk";
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-semibold flex-shrink-0"
                                                     style="width:28px;height:28px;background:#1B4FD8;font-size:0.7rem;">
                                                    @initials.ToUpperInvariant()
                                                </div>
                                                <span class="fw-semibold">@log.UserName</span>
                                            </div>
                                        </td>
                                        <td><span class="@actionCss">@log.Action</span></td>
                                        <td><span class="badge bg-light text-dark border">@log.EntityType</span></td>
                                        <td class="text-muted small">@log.RelativeTime</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
