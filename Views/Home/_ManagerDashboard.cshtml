@model PeakMetrics.Web.ViewModels.ManagerDashboardViewModel
@using System.Text.Json

@{
    var cards = new List<(string Title, string Value, string Icon)>
    {
        ("Total KPIs", Model.TotalKpis.ToString(), "bi-bar-chart-line"),
        ("On Track",   Model.OnTrack.ToString(),   "bi-graph-up-arrow"),
        ("At Risk",    Model.AtRisk.ToString(),     "bi-exclamation-circle"),
        ("Behind",     Model.Behind.ToString(),     "bi-graph-down-arrow"),
    };

    var barDatasets = new[]
    {
        new { label = "On Track", data = Model.DeptKpiStatuses.Select(d => d.OnTrack).ToList(), backgroundColor = "#22c55e" },
        new { label = "At Risk",  data = Model.DeptKpiStatuses.Select(d => d.AtRisk).ToList(),  backgroundColor = "#f59e0b" },
        new { label = "Behind",   data = Model.DeptKpiStatuses.Select(d => d.Behind).ToList(),  backgroundColor = "#ef4444" }
    };

    var trendDatasets = Model.TrendDatasets.Select((d, i) => new {
        label = d.DepartmentName,
        data = d.Values,
        borderColor = new[]{"#1B4FD8","#22c55e","#f59e0b","#ef4444","#8b5cf6","#06b6d4"}[i % 6],
        tension = 0.4,
        spanGaps = false
    }).ToList();
}

@await Html.PartialAsync("_SummaryCards", null, new ViewDataDictionary(ViewData) { ["Cards"] = cards })

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <div class="col-12 col-lg-6">
        <div class="card card-clean">
            <div class="card-body">
                <h5 class="card-title mb-3">KPI Status by Department</h5>
                <div class="canvas-wrap">
                    <canvas id="managerBarChart"
                            data-labels="@JsonSerializer.Serialize(Model.DeptKpiStatuses.Select(d => d.Department).ToList())"
                            data-datasets="@JsonSerializer.Serialize(barDatasets)"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-6">
        <div class="card card-clean">
            <div class="card-body">
                <h5 class="card-title mb-3">KPI Trend (Last 6 Months)</h5>
                <div class="canvas-wrap">
                    <canvas id="managerTrendChart"
                            data-labels="@JsonSerializer.Serialize(Model.TrendLabels)"
                            data-datasets="@JsonSerializer.Serialize(trendDatasets)"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Strategic Goals -->
    <div class="col-12 col-lg-7">
        <div class="card card-clean">
            <div class="card-body">
                <h5 class="card-title mb-3">Strategic Goals Progress</h5>
                @if (!Model.ActiveGoals.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-lightbulb fs-1 d-block mb-2 opacity-25"></i>
                        <p class="mb-0 small">No active strategic goals.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Title</th>
                                    <th>Perspective</th>
                                    <th>Status</th>
                                    <th>Target Year</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var goal in Model.ActiveGoals)
                                {
                                    <tr>
                                        <td class="fw-semibold">@goal.Title</td>
                                        <td class="text-muted small">@goal.Perspective</td>
                                        <td>@await Html.PartialAsync("_StatusBadge", goal.Status)</td>
                                        <td class="text-muted small">@(goal.TargetYear?.ToString() ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Recent KPI Logs + Notifications -->
    <div class="col-12 col-lg-5">
        <div class="card card-clean mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Recent KPI Logs</h5>
                @if (!Model.RecentLogs.Any())
                {
                    <div class="text-center py-3 text-muted">
                        <i class="bi bi-journal-text fs-1 d-block mb-2 opacity-25"></i>
                        <p class="mb-0 small">No recent log entries.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 small">
                            <thead class="table-light">
                                <tr>
                                    <th>KPI</th>
                                    <th>Logged By</th>
                                    <th>Actual</th>
                                    <th>Status</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.RecentLogs)
                                {
                                    <tr>
                                        <td class="fw-semibold">@log.KpiName</td>
                                        <td class="text-muted">@log.LoggedBy</td>
                                        <td>@log.ActualWithUnit</td>
                                        <td>@await Html.PartialAsync("_StatusBadge", log.Status)</td>
                                        <td class="text-muted">@log.RelativeTime</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @await Html.PartialAsync("_NotificationsCard", Model.UnreadNotifications)
    </div>
</div>
