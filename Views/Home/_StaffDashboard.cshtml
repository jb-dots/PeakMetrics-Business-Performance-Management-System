@model PeakMetrics.Web.ViewModels.StaffDashboardViewModel

@if (!Model.HasDepartment)
{
    <div class="row g-4">
        <div class="col-12">
            <div class="card card-clean">
                <div class="card-body text-center py-5">
                    <i class="bi bi-building-x fs-1 d-block mb-3 text-muted opacity-50"></i>
                    <h5 class="text-muted">No Department Assigned</h5>
                    <p class="text-muted mb-0">You are not assigned to a department yet. Contact your administrator.</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    var cards = new List<(string Title, string Value, string Icon)>
    {
        ("My KPIs",  Model.MyKpis.ToString(),  "bi-bar-chart-line"),
        ("On Track", Model.OnTrack.ToString(),  "bi-graph-up-arrow"),
        ("At Risk",  Model.AtRisk.ToString(),   "bi-exclamation-circle"),
        ("Behind",   Model.Behind.ToString(),   "bi-graph-down-arrow"),
    };

    @await Html.PartialAsync("_SummaryCards", null, new ViewDataDictionary(ViewData) { ["Cards"] = cards })

    <div class="row g-4 mb-4">
        <!-- My KPI List -->
        <div class="col-12 col-lg-8">
            <div class="card card-clean">
                <div class="card-body">
                    <h5 class="card-title mb-3">My KPIs</h5>
                    @if (!Model.MyKpiList.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-bar-chart fs-1 d-block mb-2 opacity-25"></i>
                            <p class="mb-0 small">No KPIs assigned to your department yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Perspective</th>
                                        <th>Target</th>
                                        <th>Actual</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var kpi in Model.MyKpiList)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@kpi.Name</td>
                                            <td class="text-muted small">@kpi.Perspective</td>
                                            <td>@kpi.Target</td>
                                            <td>@kpi.Actual</td>
                                            <td>@await Html.PartialAsync("_StatusBadge", kpi.Status)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Due for Logging + Notifications -->
        <div class="col-12 col-lg-4">
            <div class="card card-clean mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Due for Logging</h5>
                    @if (!Model.PendingKpiNames.Any())
                    {
                        <div class="d-flex align-items-center gap-2 text-success">
                            <i class="bi bi-check-circle-fill"></i>
                            <p class="mb-0 small">All KPIs are up to date for this period.</p>
                        </div>
                    }
                    else
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var name in Model.PendingKpiNames)
                            {
                                <li class="d-flex align-items-center gap-2 py-1 border-bottom">
                                    <i class="bi bi-clock text-warning"></i>
                                    <span class="small">@name</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            @await Html.PartialAsync("_NotificationsCard", Model.UnreadNotifications)
        </div>
    </div>

    <div class="row g-4">
        <!-- My Recent Logs -->
        <div class="col-12 col-lg-6">
            <div class="card card-clean">
                <div class="card-body">
                    <h5 class="card-title mb-3">My Recent Logs</h5>
                    @if (!Model.MyRecentLogs.Any())
                    {
                        <div class="text-center py-3 text-muted">
                            <i class="bi bi-journal-text fs-1 d-block mb-2 opacity-25"></i>
                            <p class="mb-0 small">No recent log entries.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 small">
                                <thead class="table-light">
                                    <tr>
                                        <th>KPI</th>
                                        <th>Actual</th>
                                        <th>Status</th>
                                        <th>Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in Model.MyRecentLogs)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@log.KpiName</td>
                                            <td>@log.ActualWithUnit</td>
                                            <td>@await Html.PartialAsync("_StatusBadge", log.Status)</td>
                                            <td class="text-muted">@log.RelativeTime</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- My Scorecard -->
        <div class="col-12 col-lg-6">
            <div class="card card-clean">
                <div class="card-body">
                    <h5 class="card-title mb-3">My Scorecard</h5>
                    @if (!Model.Scorecard.Any())
                    {
                        <div class="text-center py-3 text-muted">
                            <i class="bi bi-grid-3x3-gap fs-1 d-block mb-2 opacity-25"></i>
                            <p class="mb-0 small">No scorecard data available.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Perspective</th>
                                        <th class="text-center"><span class="status-badge status-ontrack">On Track</span></th>
                                        <th class="text-center"><span class="status-badge status-atrisk">At Risk</span></th>
                                        <th class="text-center"><span class="status-badge status-behind">Behind</span></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in Model.Scorecard)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@row.Perspective</td>
                                            <td class="text-center">@row.OnTrack</td>
                                            <td class="text-center">@row.AtRisk</td>
                                            <td class="text-center">@row.Behind</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
