@model PeakMetrics.Web.ViewModels.SuperAdminDashboardViewModel
@using System.Text.Json

@{
    var cards = new List<(string Title, string Value, string Icon)>
    {
        ("Total Users",         Model.TotalUsers.ToString(),        "bi-people"),
        ("Total Departments",   Model.TotalDepartments.ToString(),  "bi-building"),
        ("Total KPIs",          Model.TotalKpis.ToString(),         "bi-bar-chart-line"),
        ("Total Audit Entries", Model.TotalAuditEntries.ToString(), "bi-shield-lock"),
    };
}

@await Html.PartialAsync("_SummaryCards", null, new ViewDataDictionary(ViewData) { ["Cards"] = cards })

<!-- System Health Snapshot -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card card-clean">
            <div class="card-body">
                <h5 class="card-title mb-3">System Health Snapshot</h5>
                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:#f8faff;">
                            <div class="d-flex align-items-center justify-content-center rounded-3"
                                 style="width:44px;height:44px;background:#EFF6FF;">
                                <i class="bi bi-bell" style="font-size:1.2rem;color:#1B4FD8;"></i>
                            </div>
                            <div>
                                <p class="text-muted mb-0 small">Total Notifications</p>
                                <h4 class="mb-0 fw-bold">@Model.TotalNotifications</h4>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:#f8faff;">
                            <div class="d-flex align-items-center justify-content-center rounded-3"
                                 style="width:44px;height:44px;background:#EFF6FF;">
                                <i class="bi bi-journal-text" style="font-size:1.2rem;color:#1B4FD8;"></i>
                            </div>
                            <div>
                                <p class="text-muted mb-0 small">Total KPI Log Entries</p>
                                <h4 class="mb-0 fw-bold">@Model.TotalKpiLogEntries</h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Recent Audit Log -->
    <div class="col-12 col-lg-8">
        <div class="card card-clean">
            <div class="card-body">
                <h5 class="card-title mb-3">Recent Audit Log</h5>
                @if (!Model.RecentAuditLogs.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-shield-lock fs-1 d-block mb-2 opacity-25"></i>
                        <p class="mb-0 small">No audit activity recorded yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Entity Type</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.RecentAuditLogs)
                                {
                                    <tr>
                                        <td class="fw-semibold">@log.UserName</td>
                                        <td>@log.Action</td>
                                        <td><span class="badge bg-light text-dark border">@log.EntityType</span></td>
                                        <td class="text-muted small">@log.RelativeTime</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- User Role Distribution Chart -->
    <div class="col-12 col-lg-4">
        <div class="card card-clean">
            <div class="card-body">
                <h5 class="card-title mb-3">User Role Distribution</h5>
                <div class="canvas-wrap">
                    <canvas id="superAdminRoleChart"
                            data-labels="@JsonSerializer.Serialize(Model.RoleDistribution.Keys.ToList())"
                            data-datasets="@JsonSerializer.Serialize(Model.RoleDistribution.Values.ToList())"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Department Overview -->
<div class="row g-4">
    <div class="col-12">
        <div class="card card-clean">
            <div class="card-body">
                <h5 class="card-title mb-3">Department Overview</h5>
                @if (!Model.Departments.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-building fs-1 d-block mb-2 opacity-25"></i>
                        <p class="mb-0 small">No departments found.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Department</th>
                                    <th>Users</th>
                                    <th>Active KPIs</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dept in Model.Departments)
                                {
                                    <tr>
                                        <td class="fw-semibold">@dept.Name</td>
                                        <td>@dept.UserCount</td>
                                        <td>@dept.ActiveKpiCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
