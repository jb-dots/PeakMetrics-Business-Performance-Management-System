@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PeakMetrics — Business Performance Management System</title>
    <link rel="icon" type="image/png" href="~/images/peakmetrics-logo.png" />
    <link rel="shortcut icon" href="~/images/peakmetrics-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+"
          crossorigin="anonymous" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html { scroll-behavior: smooth; overflow-x: hidden; }

        body {
            font-family: "Inter", "Segoe UI", sans-serif;
            margin: 0;
            color: #1e293b;
            background: #fff;
            overflow-x: hidden;
        }

        /* ─────────────────────────────────────────────
           NAVBAR
        ───────────────────────────────────────────── */
        .pm-navbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid #e2e8f0;
            padding: 0 2rem;
            height: 66px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .pm-navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }
        .pm-navbar-logo { height: 38px; width: auto; }
        .pm-navbar-name {
            font-size: 1.1rem;
            font-weight: 800;
            color: #1B2E6B;
            letter-spacing: -0.02em;
        }
        .pm-navbar-links {
            display: flex;
            align-items: center;
            gap: 2rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .pm-navbar-links a {
            font-size: 0.88rem;
            font-weight: 600;
            color: #475569;
            text-decoration: none;
            transition: color 0.15s;
        }
        .pm-navbar-links a:hover { color: #1B2E6B; }
        .pm-btn-login {
            background: #1B2E6B;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 9px 22px;
            font-size: 0.88rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s;
            letter-spacing: 0.01em;
        }
        .pm-btn-login:hover { background: #162558; color: #fff; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(27,46,107,0.3); }

        /* ─────────────────────────────────────────────
           HERO — SPLIT LAYOUT
        ───────────────────────────────────────────── */
        .pm-hero {
            position: relative;
            overflow: hidden;
            background: linear-gradient(145deg, #0d1b4b 0%, #1B2E6B 45%, #1e40af 100%);
            color: #fff;
            padding: 80px 0 0;
            min-height: 620px;
            display: flex;
            align-items: flex-end;
        }

        /* dot-grid overlay */
        .pm-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(255,255,255,0.12) 1px, transparent 1px);
            background-size: 28px 28px;
            pointer-events: none;
        }

        /* radial glow top-right */
        .pm-hero::after {
            content: "";
            position: absolute;
            width: 700px;
            height: 700px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(99,179,237,0.18) 0%, transparent 70%);
            top: -200px;
            right: -150px;
            pointer-events: none;
        }

        .pm-hero-inner {
            position: relative;
            z-index: 1;
            width: 100%;
        }

        .pm-hero-left {
            padding-bottom: 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .pm-hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 999px;
            padding: 5px 14px;
            font-size: 0.78rem;
            font-weight: 600;
            color: #bfdbfe;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            margin-bottom: 1.5rem;
            width: fit-content;
        }
        .pm-hero-eyebrow i { font-size: 0.75rem; }

        .pm-hero-headline {
            font-family: "Manrope", sans-serif;
            font-size: clamp(2.4rem, 4.5vw, 3.6rem);
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1.08;
            margin-bottom: 1.35rem;
        }
        .pm-hero-headline span {
            background: linear-gradient(90deg, #93c5fd, #c4b5fd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .pm-hero-sub {
            font-size: 1.05rem;
            color: rgba(219,234,254,0.85);
            max-width: 480px;
            line-height: 1.65;
            margin-bottom: 2.25rem;
        }

        .pm-hero-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
        }

        .pm-btn-hero-primary {
            background: #fff;
            color: #1B2E6B;
            border: none;
            border-radius: 10px;
            padding: 13px 28px;
            font-size: 0.95rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.2s;
            box-shadow: 0 4px 18px rgba(0,0,0,0.2);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .pm-btn-hero-primary:hover { background: #eff6ff; color: #1B2E6B; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.25); }

        .pm-btn-hero-outline {
            background: transparent;
            color: rgba(255,255,255,0.9);
            border: 1.5px solid rgba(255,255,255,0.35);
            border-radius: 10px;
            padding: 12px 28px;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .pm-btn-hero-outline:hover { border-color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.08); color: #fff; }

        .pm-hero-trust {
            margin-top: 2rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-size: 0.8rem;
            color: rgba(148,163,184,0.9);
        }
        .pm-hero-trust i { color: #34d399; font-size: 0.85rem; }

        /* ── Dashboard mockup (right column) ── */
        .pm-hero-right {
            display: flex;
            align-items: flex-end;
            justify-content: center;
            padding-bottom: 0;
        }

        .pm-mockup-wrap {
            position: relative;
            width: 100%;
            max-width: 560px;
            margin: 0 auto;
        }

        .pm-mockup-browser {
            background: #1e293b;
            border-radius: 14px 14px 0 0;
            overflow: hidden;
            box-shadow: 0 -8px 40px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.08);
            transform: perspective(1200px) rotateX(3deg);
            transform-origin: bottom center;
        }

        .pm-mockup-bar {
            background: #0f172a;
            padding: 10px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .pm-mockup-dots {
            display: flex;
            gap: 5px;
        }
        .pm-mockup-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }
        .pm-mockup-dot-r { background: #ef4444; }
        .pm-mockup-dot-y { background: #f59e0b; }
        .pm-mockup-dot-g { background: #22c55e; }
        .pm-mockup-url {
            flex: 1;
            background: rgba(255,255,255,0.06);
            border-radius: 5px;
            height: 22px;
            display: flex;
            align-items: center;
            padding: 0 10px;
            gap: 6px;
            font-size: 0.7rem;
            color: rgba(148,163,184,0.7);
        }
        .pm-mockup-url i { font-size: 0.65rem; color: #22c55e; }

        .pm-mockup-body {
            background: #f1f5f9;
            padding: 14px;
            display: flex;
            gap: 10px;
        }

        /* Mockup sidebar */
        .pm-mock-sidebar {
            width: 44px;
            background: #0f172a;
            border-radius: 8px;
            padding: 10px 6px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            align-items: center;
            flex-shrink: 0;
        }
        .pm-mock-sidebar-logo {
            width: 28px;
            height: 28px;
            background: #2563eb;
            border-radius: 6px;
            margin-bottom: 4px;
        }
        .pm-mock-nav-dot {
            width: 28px;
            height: 6px;
            border-radius: 3px;
            background: rgba(255,255,255,0.12);
        }
        .pm-mock-nav-dot.active { background: #2563eb; }

        /* Mockup main content */
        .pm-mock-main { flex: 1; min-width: 0; }

        .pm-mock-topbar {
            background: #fff;
            border-radius: 7px;
            height: 28px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            padding: 0 10px;
            gap: 8px;
        }
        .pm-mock-topbar-title {
            width: 80px;
            height: 8px;
            background: #e2e8f0;
            border-radius: 4px;
        }
        .pm-mock-topbar-spacer { flex: 1; }
        .pm-mock-topbar-avatar {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #2563eb;
        }

        /* KPI stat cards row */
        .pm-mock-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            margin-bottom: 10px;
        }
        .pm-mock-stat {
            background: #fff;
            border-radius: 7px;
            padding: 8px 10px;
        }
        .pm-mock-stat-label {
            width: 50px;
            height: 5px;
            background: #e2e8f0;
            border-radius: 3px;
            margin-bottom: 6px;
        }
        .pm-mock-stat-value {
            width: 36px;
            height: 10px;
            border-radius: 4px;
            margin-bottom: 4px;
        }
        .pm-mock-stat-badge {
            width: 28px;
            height: 5px;
            border-radius: 3px;
        }
        .pm-mock-stat-blue .pm-mock-stat-value { background: #2563eb; }
        .pm-mock-stat-blue .pm-mock-stat-badge { background: #bfdbfe; }
        .pm-mock-stat-green .pm-mock-stat-value { background: #16a34a; }
        .pm-mock-stat-green .pm-mock-stat-badge { background: #bbf7d0; }
        .pm-mock-stat-amber .pm-mock-stat-value { background: #d97706; }
        .pm-mock-stat-amber .pm-mock-stat-badge { background: #fde68a; }

        /* Chart area */
        .pm-mock-charts {
            display: grid;
            grid-template-columns: 1.6fr 1fr;
            gap: 8px;
        }
        .pm-mock-chart-card {
            background: #fff;
            border-radius: 7px;
            padding: 10px;
        }
        .pm-mock-chart-title {
            width: 60px;
            height: 6px;
            background: #e2e8f0;
            border-radius: 3px;
            margin-bottom: 10px;
        }
        /* Bar chart bars */
        .pm-mock-bars {
            display: flex;
            align-items: flex-end;
            gap: 5px;
            height: 52px;
        }
        .pm-mock-bar {
            flex: 1;
            border-radius: 3px 3px 0 0;
            background: #bfdbfe;
        }
        .pm-mock-bar.hi { background: #2563eb; }
        /* Donut chart */
        .pm-mock-donut {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            background: conic-gradient(#2563eb 0% 62%, #bfdbfe 62% 80%, #fde68a 80% 100%);
            margin: 0 auto;
            position: relative;
        }
        .pm-mock-donut::after {
            content: "";
            position: absolute;
            inset: 12px;
            background: #fff;
            border-radius: 50%;
        }
        /* Table rows */
        .pm-mock-table { margin-top: 8px; }
        .pm-mock-row {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 4px 0;
            border-bottom: 1px solid #f1f5f9;
        }
        .pm-mock-row:last-child { border-bottom: none; }
        .pm-mock-row-label {
            flex: 1;
            height: 5px;
            background: #e2e8f0;
            border-radius: 3px;
        }
        .pm-mock-row-pill {
            width: 28px;
            height: 12px;
            border-radius: 999px;
        }
        .pm-mock-pill-green { background: #dcfce7; }
        .pm-mock-pill-amber { background: #fef3c7; }
        .pm-mock-pill-red   { background: #fee2e2; }
    </style>
</head>
<body>

    <!-- ── Navbar ── -->
    <nav class="pm-navbar" aria-label="Main navigation">
        <a href="/" class="pm-navbar-brand">
            <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics logo" class="pm-navbar-logo" />
            <span class="pm-navbar-name">PeakMetrics</span>
        </a>
        <ul class="pm-navbar-links d-none d-md-flex">
            <li><a href="#features">Features</a></li>
            <li><a href="#how-it-works">How It Works</a></li>
            <li><a href="#roles">Who It's For</a></li>
        </ul>
        <a href="/Home/Login" class="pm-btn-login">Sign In</a>
    </nav>

    <!-- ── Hero ── -->
    <section class="pm-hero" aria-labelledby="hero-headline">
        <div class="container pm-hero-inner">
            <div class="row align-items-end g-0">

                <!-- Left: copy -->
                <div class="col-12 col-lg-6 pm-hero-left">
                    <div class="pm-hero-eyebrow">
                        <i class="bi bi-stars"></i> Business Performance Management
                    </div>
                    <h1 class="pm-hero-headline" id="hero-headline">
                        Turn strategy into<br /><span>measurable results</span>
                    </h1>
                    <p class="pm-hero-sub">
                        PeakMetrics centralizes your KPIs, scorecards, and strategic goals so every team stays aligned — from the front line to the boardroom.
                    </p>
                    <div class="pm-hero-actions">
                        <a href="/Account/Register" class="pm-btn-hero-primary">
                            Get Started <i class="bi bi-arrow-right"></i>
                        </a>
                        <a href="#features" class="pm-btn-hero-outline">
                            <i class="bi bi-play-circle"></i> See Features
                        </a>
                    </div>
                    <div class="pm-hero-trust">
                        <i class="bi bi-check-circle-fill"></i>
                        Role-based access &nbsp;·&nbsp;
                        <i class="bi bi-check-circle-fill"></i>
                        Real-time KPI tracking &nbsp;·&nbsp;
                        <i class="bi bi-check-circle-fill"></i>
                        Balanced Scorecards
                    </div>
                </div>

                <!-- Right: dashboard mockup -->
                <div class="col-12 col-lg-6 pm-hero-right d-none d-lg-flex">
                    <div class="pm-mockup-wrap">
                        <div class="pm-mockup-browser">
                            <!-- Browser chrome -->
                            <div class="pm-mockup-bar">
                                <div class="pm-mockup-dots">
                                    <div class="pm-mockup-dot pm-mockup-dot-r"></div>
                                    <div class="pm-mockup-dot pm-mockup-dot-y"></div>
                                    <div class="pm-mockup-dot pm-mockup-dot-g"></div>
                                </div>
                                <div class="pm-mockup-url">
                                    <i class="bi bi-lock-fill"></i>
                                    peakmetrics.app/dashboard
                                </div>
                            </div>
                            <!-- App body -->
                            <div class="pm-mockup-body">
                                <!-- Mini sidebar -->
                                <div class="pm-mock-sidebar">
                                    <div class="pm-mock-sidebar-logo"></div>
                                    <div class="pm-mock-nav-dot active"></div>
                                    <div class="pm-mock-nav-dot"></div>
                                    <div class="pm-mock-nav-dot"></div>
                                    <div class="pm-mock-nav-dot"></div>
                                    <div class="pm-mock-nav-dot"></div>
                                </div>
                                <!-- Main content -->
                                <div class="pm-mock-main">
                                    <div class="pm-mock-topbar">
                                        <div class="pm-mock-topbar-title"></div>
                                        <div class="pm-mock-topbar-spacer"></div>
                                        <div class="pm-mock-topbar-avatar"></div>
                                    </div>
                                    <!-- Stat cards -->
                                    <div class="pm-mock-stats">
                                        <div class="pm-mock-stat pm-mock-stat-blue">
                                            <div class="pm-mock-stat-label"></div>
                                            <div class="pm-mock-stat-value"></div>
                                            <div class="pm-mock-stat-badge"></div>
                                        </div>
                                        <div class="pm-mock-stat pm-mock-stat-green">
                                            <div class="pm-mock-stat-label"></div>
                                            <div class="pm-mock-stat-value"></div>
                                            <div class="pm-mock-stat-badge"></div>
                                        </div>
                                        <div class="pm-mock-stat pm-mock-stat-amber">
                                            <div class="pm-mock-stat-label"></div>
                                            <div class="pm-mock-stat-value"></div>
                                            <div class="pm-mock-stat-badge"></div>
                                        </div>
                                    </div>
                                    <!-- Charts row -->
                                    <div class="pm-mock-charts">
                                        <div class="pm-mock-chart-card">
                                            <div class="pm-mock-chart-title"></div>
                                            <div class="pm-mock-bars">
                                                <div class="pm-mock-bar" style="height:35%"></div>
                                                <div class="pm-mock-bar" style="height:55%"></div>
                                                <div class="pm-mock-bar hi" style="height:80%"></div>
                                                <div class="pm-mock-bar" style="height:60%"></div>
                                                <div class="pm-mock-bar hi" style="height:90%"></div>
                                                <div class="pm-mock-bar" style="height:70%"></div>
                                                <div class="pm-mock-bar hi" style="height:100%"></div>
                                            </div>
                                            <div class="pm-mock-table">
                                                <div class="pm-mock-row">
                                                    <div class="pm-mock-row-label"></div>
                                                    <div class="pm-mock-row-pill pm-mock-pill-green"></div>
                                                </div>
                                                <div class="pm-mock-row">
                                                    <div class="pm-mock-row-label" style="width:55%"></div>
                                                    <div class="pm-mock-row-pill pm-mock-pill-amber"></div>
                                                </div>
                                                <div class="pm-mock-row">
                                                    <div class="pm-mock-row-label" style="width:70%"></div>
                                                    <div class="pm-mock-row-pill pm-mock-pill-green"></div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="pm-mock-chart-card">
                                            <div class="pm-mock-chart-title"></div>
                                            <div class="pm-mock-donut"></div>
                                            <div class="pm-mock-table" style="margin-top:10px">
                                                <div class="pm-mock-row">
                                                    <div class="pm-mock-row-label"></div>
                                                    <div class="pm-mock-row-pill pm-mock-pill-green"></div>
                                                </div>
                                                <div class="pm-mock-row">
                                                    <div class="pm-mock-row-label" style="width:60%"></div>
                                                    <div class="pm-mock-row-pill pm-mock-pill-red"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- ── Stats bar ── -->
    <div style="background:#fff; border-bottom:1px solid #e2e8f0;">
        <div class="container">
            <div class="row g-0 text-center" style="border-left:1px solid #e2e8f0;">
                <div class="col-6 col-md-3" style="padding:1.6rem 1rem; border-right:1px solid #e2e8f0;">
                    <div style="font-size:1.9rem;font-weight:800;color:#1B2E6B;letter-spacing:-0.03em;line-height:1;">4</div>
                    <div style="font-size:0.8rem;color:#64748b;margin-top:4px;font-weight:500;">User Roles</div>
                </div>
                <div class="col-6 col-md-3" style="padding:1.6rem 1rem; border-right:1px solid #e2e8f0;">
                    <div style="font-size:1.9rem;font-weight:800;color:#1B2E6B;letter-spacing:-0.03em;line-height:1;">4</div>
                    <div style="font-size:0.8rem;color:#64748b;margin-top:4px;font-weight:500;">BSC Perspectives</div>
                </div>
                <div class="col-6 col-md-3" style="padding:1.6rem 1rem; border-right:1px solid #e2e8f0;">
                    <div style="font-size:1.9rem;font-weight:800;color:#1B2E6B;letter-spacing:-0.03em;line-height:1;">Real-time</div>
                    <div style="font-size:0.8rem;color:#64748b;margin-top:4px;font-weight:500;">KPI Monitoring</div>
                </div>
                <div class="col-6 col-md-3" style="padding:1.6rem 1rem; border-right:1px solid #e2e8f0;">
                    <div style="font-size:1.9rem;font-weight:800;color:#1B2E6B;letter-spacing:-0.03em;line-height:1;">360°</div>
                    <div style="font-size:0.8rem;color:#64748b;margin-top:4px;font-weight:500;">Performance View</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Features ── -->
    <section style="padding:90px 0; background:#f8fafc;" id="features" aria-labelledby="features-title">
        <div class="container">
            <div class="text-center mb-5">
                <span style="display:inline-block;background:#eff6ff;color:#1B2E6B;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:5px 14px;border-radius:999px;margin-bottom:1rem;">Features</span>
                <h2 style="font-family:'Manrope',sans-serif;font-size:clamp(1.7rem,3vw,2.3rem);font-weight:800;letter-spacing:-0.02em;color:#0f172a;margin-bottom:0.5rem;" id="features-title">
                    Everything you need to manage performance
                </h2>
                <p style="color:#64748b;font-size:1rem;max-width:520px;margin:0 auto;">
                    Purpose-built tools for every stage of your performance management cycle.
                </p>
