@{
    static string quickSeverityClass(AlertSeverity severity)
        => severity switch
        {
            AlertSeverity.Critical => "quick-severity-critical",
            AlertSeverity.Warning => "quick-severity-warning",
            _ => "quick-severity-standard"
        };

    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    var title = ViewData["Title"]?.ToString() ?? "PeakMetrics";
    var logoFallbackScript = "this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none'); this.nextElementSibling.nextElementSibling.classList.remove('d-none');";
    var isNotificationsPage = string.Equals(currentAction, "Notifications", StringComparison.OrdinalIgnoreCase);
    var isProfilePage = string.Equals(currentAction, "Profile", StringComparison.OrdinalIgnoreCase);
    var quickNotifications = (ViewData["QuickNotifications"] as IReadOnlyList<NotificationItemViewModel>) ?? Array.Empty<NotificationItemViewModel>();
    var unreadQuickNotifications = quickNotifications.Count(n => !n.Read);
    var menuItems = new[]
    {
        new { Action = "Dashboard", Label = "Dashboard", Icon = "bi-speedometer2" },
        new { Action = "KPITracking", Label = "KPI Tracking", Icon = "bi-bullseye" },
        new { Action = "BalancedScorecard", Label = "Balanced Scorecards", Icon = "bi-grid-3x3-gap" },
        new { Action = "PerformanceAnalytics", Label = "Performance Analytics", Icon = "bi-bar-chart" },
        new { Action = "StrategicPlanning", Label = "Strategic Planning", Icon = "bi-lightbulb" },
        new { Action = "ExecutiveReporting", Label = "Executive Reporting", Icon = "bi-file-earmark-text" },
        new { Action = "DepartmentManagement", Label = "Department Management", Icon = "bi-building" },
        new { Action = "AuditLog", Label = "Audit Log", Icon = "bi-shield-lock" },
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - PeakMetrics</title>
    <link rel="icon" type="image/png" href="~/images/peakmetrics-logo.png" />
    <link rel="shortcut icon" href="~/images/peakmetrics-logo.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body data-page="@currentAction">
    @if (currentAction == "Login")
    {
        @RenderBody()
    }
    else
    {
        <div class="app-shell d-flex">
            <aside class="app-sidebar d-none d-md-flex" aria-label="Primary navigation">
                <div class="app-logo-wrap">
                    <div class="app-brand">
                        <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics logo" class="app-logo-image" onerror="@logoFallbackScript" />
                        <h3 class="app-logo app-logo-fallback mb-0 d-none">PeakMetrics</h3>
                        <p class="app-tagline app-logo-fallback mb-0 d-none">Monitor. Measure. Perform.</p>
                    </div>
                </div>
                <nav class="app-nav">
                    @foreach (var item in menuItems)
                    {
                        var isActive = string.Equals(item.Action, currentAction, StringComparison.OrdinalIgnoreCase);
                        <a asp-controller="Home" asp-action="@item.Action" class="app-nav-link @(isActive ? "active" : string.Empty)" data-nav-label="@item.Label" title="@item.Label">
                            <span class="app-nav-icon">
                                <i class="bi @item.Icon"></i>
                            </span>
                            <span class="app-nav-label">@item.Label</span>
                        </a>
                    }
                </nav>
            </aside>

            <div class="offcanvas offcanvas-start app-sidebar-offcanvas d-md-none" tabindex="-1" id="mobileSidebar" aria-labelledby="mobileSidebarLabel">
                <div class="offcanvas-header app-logo-wrap">
                    <div class="app-brand app-brand-mobile">
                        <span class="visually-hidden" id="mobileSidebarLabel">PeakMetrics navigation</span>
                        <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics logo" class="app-logo-image" onerror="@logoFallbackScript" />
                        <h3 class="app-logo app-logo-fallback mb-0 d-none">PeakMetrics</h3>
                        <p class="app-tagline app-logo-fallback mb-0 d-none">Monitor. Measure. Perform.</p>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body p-0">
                    <nav class="app-nav">
                        @foreach (var item in menuItems)
                        {
                            var isActive = string.Equals(item.Action, currentAction, StringComparison.OrdinalIgnoreCase);
                            <a asp-controller="Home" asp-action="@item.Action" class="app-nav-link @(isActive ? "active" : string.Empty)">
                                <span class="app-nav-icon">
                                    <i class="bi @item.Icon"></i>
                                </span>
                                <span class="app-nav-label">@item.Label</span>
                            </a>
                        }
                    </nav>
                </div>
            </div>

            <main class="app-main d-flex flex-column">
                <header class="app-topbar d-flex align-items-center justify-content-between">
                    <div class="app-topbar-left d-flex align-items-center gap-2">
                        <button type="button" class="topbar-icon-btn app-desktop-collapse-toggle d-none d-md-inline-flex" id="desktopSidebarToggle" aria-label="Collapse sidebar" aria-pressed="false">
                            <i class="bi bi-layout-sidebar"></i>
                        </button>
                        <button type="button" class="topbar-icon-btn app-menu-toggle d-md-none" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar" aria-controls="mobileSidebar" aria-label="Open navigation menu">
                            <i class="bi bi-list"></i>
                        </button>
                        <h4 class="mb-0 app-page-title">@title</h4>
                    </div>
                    <div class="app-topbar-actions">
                        <div class="topbar-dropdown-wrap" id="notificationDropdownWrap">
                            <button type="button" class="topbar-icon-btn @(isNotificationsPage ? "active" : string.Empty)" id="notificationDropdownToggle" aria-expanded="false" aria-controls="notificationDropdownPanel" aria-label="Open notifications quick panel">
                                <i class="bi bi-bell"></i>
                                <span id="topbarNotificationBadge" class="topbar-badge" data-default-count="@unreadQuickNotifications">@unreadQuickNotifications</span>
                            </button>
                            <div class="notification-dropdown card-clean" id="notificationDropdownPanel" hidden>
                                <div class="notification-dropdown-header">
                                    <div>
                                        <h6 class="mb-0 fw-semibold">Notifications</h6>
                                        <small class="text-muted"><span id="quickNotificationUnreadCount">@unreadQuickNotifications</span> unread</small>
                                    </div>
                                    <a asp-controller="Home" asp-action="Notifications" class="small text-decoration-none">View all</a>
                                </div>
                                <div class="notification-dropdown-list">
                                    @if (quickNotifications.Count == 0)
                                    {
                                        <p class="text-muted small px-3 py-3 mb-0">No notifications right now.</p>
                                    }
                                    @foreach (var item in quickNotifications)
                                    {
                                        <button type="button" class="quick-notification-item @(item.Read ? string.Empty : "notification-unread") @quickSeverityClass(item.Severity)" data-read="@(item.Read ? "true" : "false")">
                                            <div class="quick-notification-main">
                                                <div class="quick-notification-title-wrap">
                                                    <p class="quick-notification-title">@item.Title</p>
                                                    <span class="quick-notification-time">@item.Time</span>
                                                </div>
                                                <p class="quick-notification-message">@item.Message</p>
                                            </div>
                                            @if (!item.Read)
                                            {
                                                <span class="notification-dot quick-notification-dot"></span>
                                            }
                                        </button>
                                    }
                                </div>
                                <div class="notification-dropdown-footer">
                                    <button type="button" class="btn btn-sm text-primary px-0" id="markAllTopbarNotificationsRead">Mark all as read</button>
                                </div>
                            </div>
                        </div>
                        <a asp-controller="Home" asp-action="Profile" class="app-user-pill-link @(isProfilePage ? "active" : string.Empty)" aria-label="Open profile page">
                            <span class="app-user-pill">JD</span>
                        </a>
                    </div>
                </header>
                <section class="app-content">
                    @RenderBody()
                </section>
            </main>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
