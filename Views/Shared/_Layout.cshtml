@using PeakMetrics.Web.ViewModels
@{
    static string quickSeverityClass(AlertSeverity severity)
        => severity switch
        {
            AlertSeverity.Critical => "quick-severity-critical",
            AlertSeverity.Warning  => "quick-severity-warning",
            _                      => "quick-severity-standard"
        };

    var currentAction       = ViewContext.RouteData.Values["action"]?.ToString() ?? "Dashboard";
    var title               = ViewData["Title"]?.ToString() ?? "PeakMetrics";
    var isNotificationsPage = string.Equals(currentAction, "Notifications", StringComparison.OrdinalIgnoreCase);
    var isProfilePage       = string.Equals(currentAction, "Profile",       StringComparison.OrdinalIgnoreCase);

    var quickNotifications      = (ViewData["QuickNotifications"] as IReadOnlyList<NotificationItemViewModel>) ?? Array.Empty<NotificationItemViewModel>();
    var unreadQuickNotifications = (int)(ViewData["UnreadQuickNotifications"] ?? 0);

    var sessionUserName     = ViewData["SessionUserName"]?.ToString()     ?? "User";
    var sessionUserRole     = ViewData["SessionUserRole"]?.ToString()     ?? string.Empty;
    var sessionUserInitials = ViewData["SessionUserInitials"]?.ToString() ?? "U";

    var menuItems = new[]
    {
        new { Action = "Dashboard",           Label = "Dashboard",            Icon = "bi-speedometer2",       Roles = new[]{ "Super Admin","Administrator","Manager","Staff","Executive" } },
        new { Action = "KPITracking",         Label = "KPI Tracking",         Icon = "bi-bullseye",           Roles = new[]{ "Super Admin","Administrator","Manager","Staff","Executive" } },
        new { Action = "BalancedScorecard",   Label = "Balanced Scorecards",  Icon = "bi-grid-3x3-gap",       Roles = new[]{ "Super Admin","Manager","Staff","Executive" } },
        new { Action = "PerformanceAnalytics",Label = "Performance Analytics",Icon = "bi-bar-chart",          Roles = new[]{ "Super Admin","Manager","Executive" } },
        new { Action = "StrategicPlanning",   Label = "Strategic Planning",   Icon = "bi-lightbulb",          Roles = new[]{ "Super Admin","Manager","Executive" } },
        new { Action = "ExecutiveReporting",  Label = "Executive Reporting",  Icon = "bi-file-earmark-text",  Roles = new[]{ "Super Admin","Manager","Executive" } },
        new { Action = "DepartmentManagement",Label = "Department Management",Icon = "bi-building",           Roles = new[]{ "Super Admin","Administrator" } },
        new { Action = "UserManagement",      Label = "User Management",      Icon = "bi-people",             Roles = new[]{ "Super Admin","Administrator" } },
        new { Action = "Notifications",       Label = "Notifications",        Icon = "bi-bell",               Roles = new[]{ "Administrator" } },
        new { Action = "ExecutiveReporting",  Label = "Reports",              Icon = "bi-file-earmark-bar-graph", Roles = new[]{ "Administrator" } },
        new { Action = "AuditLog",            Label = "Audit Log",            Icon = "bi-shield-lock",        Roles = new[]{ "Super Admin" } },
    };

    var visibleMenuItems = menuItems.Where(m => m.Roles.Contains(sessionUserRole)).ToArray();
    var canManageKpis    = sessionUserRole is "Super Admin" or "Administrator" or "Manager";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - PeakMetrics</title>
    <link rel="icon" type="image/png" href="~/images/peakmetrics-logo.png" />
    <link rel="shortcut icon" href="~/images/peakmetrics-logo.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body data-page="@currentAction">
    @if (currentAction == "Login")
    {
        @RenderBody()
    }
    else
    {
        <div class="app-shell d-flex">
            <!-- ── Desktop sidebar ── -->
            <aside class="app-sidebar d-none d-md-flex" aria-label="Primary navigation">
                <div class="app-logo-wrap">
                    <div class="app-brand">
                        <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics logo" class="app-logo-image" />
                        <span class="app-logo-fallback-text" aria-hidden="true">PeakMetrics</span>
                    </div>
                </div>
                <nav class="app-nav" aria-label="Main menu">
                    @foreach (var item in visibleMenuItems)
                    {
                        var isActive = string.Equals(item.Action, currentAction, StringComparison.OrdinalIgnoreCase);
                        <a asp-controller="Home" asp-action="@item.Action"
                           class="app-nav-link @(isActive ? "active" : string.Empty)"
                           title="@item.Label">
                            <span class="app-nav-icon"><i class="bi @item.Icon"></i></span>
                            <span class="app-nav-label">@item.Label</span>
                        </a>
                    }
                </nav>

                <!-- Sidebar footer: clickable avatar → popup with Profile + Sign out -->
                <div class="app-sidebar-footer">
                    <div class="sidebar-user-popup-wrap" id="sidebarUserWrap">
                        <button type="button" class="sidebar-user-btn" id="sidebarUserToggle"
                                aria-expanded="false" aria-label="User menu">
                            <div class="sidebar-user-avatar">@sessionUserInitials</div>
                            <div class="sidebar-user-meta">
                                <span class="sidebar-user-name">@sessionUserName</span>
                                <span class="sidebar-user-role">@sessionUserRole</span>
                            </div>
                            <i class="bi bi-chevron-up sidebar-user-chevron"></i>
                        </button>
                        <div class="sidebar-user-popup" id="sidebarUserPopup" hidden>
                            <div class="sidebar-popup-header">
                                <div class="sidebar-popup-avatar">@sessionUserInitials</div>
                                <div>
                                    <div class="sidebar-popup-name">@sessionUserName</div>
                                    <div class="sidebar-popup-role">@sessionUserRole</div>
                                </div>
                            </div>
                            <div class="sidebar-popup-divider"></div>
                            <a asp-controller="Home" asp-action="Profile" class="sidebar-popup-item">
                                <i class="bi bi-person-circle"></i><span>Profile</span>
                            </a>
                            <button type="button" class="sidebar-popup-item sidebar-popup-logout" id="logoutTrigger">
                                <i class="bi bi-box-arrow-right"></i><span>Sign out</span>
                            </button>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- ── Mobile offcanvas sidebar ── -->
            <div class="offcanvas offcanvas-start app-sidebar-offcanvas d-md-none" tabindex="-1" id="mobileSidebar" aria-labelledby="mobileSidebarLabel">
                <div class="offcanvas-header app-logo-wrap">
                    <div class="app-brand app-brand-mobile">
                        <span class="visually-hidden" id="mobileSidebarLabel">PeakMetrics navigation</span>
                        <img src="~/images/peakmetrics-logo.png" alt="PeakMetrics logo" class="app-logo-image" />
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body p-0 d-flex flex-column">
                    <nav class="app-nav flex-grow-1" aria-label="Main menu">
                        @foreach (var item in visibleMenuItems)
                        {
                            var isActive = string.Equals(item.Action, currentAction, StringComparison.OrdinalIgnoreCase);
                            <a asp-controller="Home" asp-action="@item.Action"
                               class="app-nav-link @(isActive ? "active" : string.Empty)">
                                <span class="app-nav-icon"><i class="bi @item.Icon"></i></span>
                                <span class="app-nav-label">@item.Label</span>
                            </a>
                        }
                    </nav>
                    <div class="app-sidebar-footer">
                        <div class="sidebar-user-popup-wrap" id="sidebarUserWrapMobile">
                            <button type="button" class="sidebar-user-btn" id="sidebarUserToggleMobile"
                                    aria-expanded="false" aria-label="User menu">
                                <div class="sidebar-user-avatar">@sessionUserInitials</div>
                                <div class="sidebar-user-meta">
                                    <span class="sidebar-user-name">@sessionUserName</span>
                                    <span class="sidebar-user-role">@sessionUserRole</span>
                                </div>
                                <i class="bi bi-chevron-up sidebar-user-chevron"></i>
                            </button>
                            <div class="sidebar-user-popup" id="sidebarUserPopupMobile" hidden>
                                <div class="sidebar-popup-header">
                                    <div class="sidebar-popup-avatar">@sessionUserInitials</div>
                                    <div>
                                        <div class="sidebar-popup-name">@sessionUserName</div>
                                        <div class="sidebar-popup-role">@sessionUserRole</div>
                                    </div>
                                </div>
                                <div class="sidebar-popup-divider"></div>
                                <a asp-controller="Home" asp-action="Profile" class="sidebar-popup-item">
                                    <i class="bi bi-person-circle"></i><span>Profile</span>
                                </a>
                                <button type="button" class="sidebar-popup-item sidebar-popup-logout" id="logoutTriggerMobile">
                                    <i class="bi bi-box-arrow-right"></i><span>Sign out</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Main content ── -->
            <main class="app-main d-flex flex-column">
                <header class="app-topbar d-flex align-items-center justify-content-between">
                    <div class="app-topbar-left d-flex align-items-center gap-2">
                        <button type="button" class="topbar-icon-btn app-desktop-collapse-toggle d-none d-md-inline-flex"
                                id="desktopSidebarToggle" aria-label="Collapse sidebar" aria-pressed="false">
                            <i class="bi bi-layout-sidebar"></i>
                        </button>
                        <button type="button" class="topbar-icon-btn app-menu-toggle d-md-none"
                                data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar"
                                aria-controls="mobileSidebar" aria-label="Open navigation menu">
                            <i class="bi bi-list"></i>
                        </button>
                        <h4 class="mb-0 app-page-title">@title</h4>
                    </div>
                    <div class="app-topbar-actions">
                        <!-- Notification bell -->
                        <div class="topbar-dropdown-wrap" id="notificationDropdownWrap">
                            <button type="button"
                                    class="topbar-icon-btn @(isNotificationsPage ? "active" : string.Empty)"
                                    id="notificationDropdownToggle"
                                    aria-expanded="false"
                                    aria-controls="notificationDropdownPanel"
                                    aria-label="Open notifications quick panel">
                                <i class="bi bi-bell"></i>
                                <span id="topbarNotificationBadge" class="topbar-badge"
                                      data-default-count="@unreadQuickNotifications">@unreadQuickNotifications</span>
                            </button>
                            <div class="notification-dropdown card-clean" id="notificationDropdownPanel" hidden>
                                <div class="notification-dropdown-header">
                                    <div>
                                        <h6 class="mb-0 fw-semibold">Notifications</h6>
                                        <small class="text-muted">
                                            <span id="quickNotificationUnreadCount">@unreadQuickNotifications</span> unread
                                        </small>
                                    </div>
                                    <a asp-controller="Home" asp-action="Notifications" class="small text-decoration-none">View all</a>
                                </div>
                                <div class="notification-dropdown-list">
                                    @if (quickNotifications.Count == 0)
                                    {
                                        <p class="text-muted small px-3 py-3 mb-0">No notifications right now.</p>
                                    }
                                    @foreach (var item in quickNotifications)
                                    {
                                        <button type="button"
                                                class="quick-notification-item @(item.Read ? string.Empty : "notification-unread") @quickSeverityClass(item.Severity)"
                                                data-read="@(item.Read ? "true" : "false")">
                                            <div class="quick-notification-main">
                                                <div class="quick-notification-title-wrap">
                                                    <p class="quick-notification-title">@item.Title</p>
                                                    <span class="quick-notification-time">@item.Time</span>
                                                </div>
                                                <p class="quick-notification-message">@item.Message</p>
                                            </div>
                                            @if (!item.Read)
                                            {
                                                <span class="notification-dot quick-notification-dot"></span>
                                            }
                                        </button>
                                    }
                                </div>
                                <div class="notification-dropdown-footer">
                                    <button type="button" class="btn btn-sm text-primary px-0" id="markAllTopbarNotificationsRead">
                                        Mark all as read
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Profile dropdown -->
                        <div class="topbar-dropdown-wrap" id="profileDropdownWrap">
                            <button type="button"
                                    class="app-user-pill-link @(isProfilePage ? "active" : string.Empty)"
                                    id="profileDropdownToggle"
                                    aria-expanded="false"
                                    aria-label="Open user menu">
                                <span class="app-user-pill">@sessionUserInitials</span>
                            </button>
                            <div class="profile-dropdown" id="profileDropdownPanel" hidden>
                                <div class="profile-dropdown-header">
                                    <div class="profile-dropdown-avatar">@sessionUserInitials</div>
                                    <div>
                                        <div class="profile-dropdown-name">@sessionUserName</div>
                                        <div class="profile-dropdown-role">@sessionUserRole</div>
                                    </div>
                                </div>
                                <div class="profile-dropdown-divider"></div>
                                <a asp-controller="Home" asp-action="Profile" class="profile-dropdown-item">
                                    <i class="bi bi-person-circle"></i>
                                    <span>Profile</span>
                                </a>
                                <button type="button" class="profile-dropdown-item profile-dropdown-logout" id="profileLogoutTrigger">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Sign out</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </header>

                <section class="app-content">
                    @RenderBody()
                </section>
            </main>
        </div>

        <!-- ── Logout confirmation modal ── -->
        <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-sm">
                <div class="modal-content logout-modal-content">
                    <div class="logout-modal-icon">
                        <i class="bi bi-box-arrow-right"></i>
                    </div>
                    <h5 class="logout-modal-title" id="logoutModalLabel">Sign out?</h5>
                    <p class="logout-modal-body">You'll need to sign in again to access your dashboard.</p>
                    <div class="logout-modal-actions">
                        <button type="button" class="btn logout-cancel-btn" data-bs-dismiss="modal">Cancel</button>
                        <form asp-controller="Home" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn logout-confirm-btn">Sign out</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js" integrity="sha384-JUh163oCRItcbPme8pYnROHQMC6fNKTBWtRG3I3I0erJkzNgL7uxKlNwcrcFKeqF" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" integrity="sha384-1H217gwSVyLSIfaLxHbE7dRb3v4mYCKbpQvzx0cegeju1MVsGrX5xXxAvs/HgeFs" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.21.0/dist/jquery.validate.min.js" integrity="sha384-INLNT6YPpjCRFM2xpOexEE3T4i2mIigf+Kr19b7a59RFtrVBZQzZWXkGuiMA/q1r" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js" integrity="sha384-DU2a51mTHKDhpXhTyJQ++hP8L9L8Gc48TlvbzBmUof71V7kNVs4ELmaVJKPxcAGn" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (currentAction != "Login")
    {
        <script>
            (function () {
                const modal = new bootstrap.Modal(document.getElementById('logoutModal'));

                // Sidebar user popup toggle (desktop)
                const sidebarToggle = document.getElementById('sidebarUserToggle');
                const sidebarPopup  = document.getElementById('sidebarUserPopup');
                if (sidebarToggle && sidebarPopup) {
                    sidebarToggle.addEventListener('click', function () {
                        sidebarPopup.hidden = !sidebarPopup.hidden;
                        sidebarToggle.setAttribute('aria-expanded', !sidebarPopup.hidden);
                    });
                    document.addEventListener('click', function (e) {
                        if (!sidebarPopup.hidden && !document.getElementById('sidebarUserWrap').contains(e.target)) {
                            sidebarPopup.hidden = true;
                        }
                    });
                }

                // Sidebar user popup toggle (mobile)
                const sidebarToggleMobile = document.getElementById('sidebarUserToggleMobile');
                const sidebarPopupMobile  = document.getElementById('sidebarUserPopupMobile');
                if (sidebarToggleMobile && sidebarPopupMobile) {
                    sidebarToggleMobile.addEventListener('click', function () {
                        sidebarPopupMobile.hidden = !sidebarPopupMobile.hidden;
                    });
                }

                // Logout triggers
                document.getElementById('logoutTrigger')?.addEventListener('click', () => {
                    if (sidebarPopup) sidebarPopup.hidden = true;
                    modal.show();
                });
                document.getElementById('logoutTriggerMobile')?.addEventListener('click', () => {
                    if (sidebarPopupMobile) sidebarPopupMobile.hidden = true;
                    modal.show();
                });

                // Profile dropdown logout (topbar)
                document.getElementById('profileLogoutTrigger')?.addEventListener('click', () => {
                    document.getElementById('profileDropdownPanel').hidden = true;
                    modal.show();
                });

                // Profile dropdown toggle (topbar)
                const profileToggle = document.getElementById('profileDropdownToggle');
                const profilePanel  = document.getElementById('profileDropdownPanel');
                if (profileToggle && profilePanel) {
                    profileToggle.addEventListener('click', function () {
                        profilePanel.hidden = !profilePanel.hidden;
                        profileToggle.setAttribute('aria-expanded', !profilePanel.hidden);
                    });
                    document.addEventListener('click', function (e) {
                        if (!profilePanel.hidden && !document.getElementById('profileDropdownWrap').contains(e.target)) {
                            profilePanel.hidden = true;
                            profileToggle.setAttribute('aria-expanded', 'false');
                        }
                    });
                }
            })();
        </script>
    }
</body>
</html>
